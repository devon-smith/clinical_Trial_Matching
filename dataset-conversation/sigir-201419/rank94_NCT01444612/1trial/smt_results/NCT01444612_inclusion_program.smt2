;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_age_value_recorded_now_in_years Real) ;; {"when_to_set_to_value":"Set to the patient's current age in years if it is known and documented.","when_to_set_to_null":"Set to null if the patient's current age in years is unknown, not documented, or cannot be determined.","meaning":"Numeric value indicating the patient's current age in years."} // "aged ≥ 18 years"

;; ===================== Constraint Assertions (REQ 0) =====================
(assert
  (! (>= patient_age_value_recorded_now_in_years 18)
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must be aged ≥ 18 years."

;; ===================== Declarations for the inclusion criterion (REQ 1) =====================
(declare-const patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever had a diagnosis of malignant neoplastic disease (cancer) recorded in their medical history.","when_to_set_to_false":"Set to false if the patient has never had a diagnosis of malignant neoplastic disease (cancer) recorded in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever had a diagnosis of malignant neoplastic disease (cancer).","meaning":"Boolean indicating whether the patient has ever had a diagnosis of malignant neoplastic disease (cancer) in their history."} // "cancer"
(declare-const patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory@@primary_inpatient_discharge_diagnosis Bool) ;; {"when_to_set_to_true":"Set to true if the diagnosis of malignant neoplastic disease (cancer) was recorded as a primary inpatient discharge diagnosis.","when_to_set_to_false":"Set to false if the diagnosis was not a primary inpatient discharge diagnosis.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the diagnosis was a primary inpatient discharge diagnosis.","meaning":"Boolean indicating whether the diagnosis of malignant neoplastic disease (cancer) was a primary inpatient discharge diagnosis."} // "primary inpatient discharge diagnosis of cancer"
(declare-const patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory@@occurred_during_index_hospitalization Bool) ;; {"when_to_set_to_true":"Set to true if the diagnosis of malignant neoplastic disease (cancer) occurred during the index hospitalization.","when_to_set_to_false":"Set to false if the diagnosis did not occur during the index hospitalization.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the diagnosis occurred during the index hospitalization.","meaning":"Boolean indicating whether the diagnosis of malignant neoplastic disease (cancer) occurred during the index hospitalization."} // "during the index hospitalization"

;; ===================== Auxiliary Assertions (REQ 1) =====================
;; Qualifier variable implies stem variable: if there is a primary inpatient discharge diagnosis of cancer in the history, then there is a diagnosis of cancer in the history
(assert
  (! (=> patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory@@primary_inpatient_discharge_diagnosis
         patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory)
     :named REQ1_AUXILIARY0)) ;; "primary inpatient discharge diagnosis of cancer"

;; Qualifier variable implies stem variable: if there is a diagnosis of cancer during the index hospitalization, then there is a diagnosis of cancer in the history
(assert
  (! (=> patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory@@occurred_during_index_hospitalization
         patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory)
     :named REQ1_AUXILIARY1)) ;; "diagnosis of cancer during the index hospitalization"

;; ===================== Constraint Assertions (REQ 1) =====================
;; The patient must have at least one record of a primary inpatient discharge diagnosis of cancer during the index hospitalization
(assert
  (! (and patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory@@primary_inpatient_discharge_diagnosis
          patient_has_diagnosis_of_malignant_neoplastic_disease_inthehistory@@occurred_during_index_hospitalization)
     :named REQ1_COMPONENT0_OTHER_REQUIREMENTS)) ;; "at least one record of a primary inpatient discharge diagnosis of cancer during the index hospitalization"

;; ===================== Declarations for the criterion (REQ 2) =====================
