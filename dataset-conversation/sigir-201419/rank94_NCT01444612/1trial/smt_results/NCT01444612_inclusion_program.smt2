(declare-const patient_has_undergone_anticoagulant_therapy_with_unfractionated_heparin_now@@administered_as_thromboprophylaxis_therapy@@identified_by_code@@temporalcontext_within_day_prior_to_or_two_days_after_cancer_related_surgery_during_index_hospitalization Bool) ;; {"when_to_set_to_true":"Set to true if the patient has undergone anticoagulant therapy with unfractionated heparin now, administered as thromboprophylaxis therapy, identified by a code, and the therapy occurred during the day prior to or two days after cancer-related surgery during the index hospitalization.","when_to_set_to_false":"Set to false if the patient has not undergone anticoagulant therapy with unfractionated heparin now, or it was not administered as thromboprophylaxis therapy, or not identified by a code, or did not occur during the specified perioperative window.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has undergone anticoagulant therapy with unfractionated heparin now, administered as thromboprophylaxis therapy, identified by a code, and occurred during the specified perioperative window.","meaning":"Boolean indicating whether the patient has undergone anticoagulant therapy with unfractionated heparin now, administered as thromboprophylaxis therapy, identified by a code, and occurring during the day prior to or two days after cancer-related surgery during the index hospitalization."} // "unfractionated heparin"

