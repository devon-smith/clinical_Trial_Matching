(declare-const patient_has_undergone_surgical_procedure_now@@cancer_related_indication Bool) ;; {"when_to_set_to_true":"Set to true if the surgical procedure undergone by the patient during the index hospitalization was performed for a cancer-related indication.","when_to_set_to_false":"Set to false if the surgical procedure undergone by the patient during the index hospitalization was not performed for a cancer-related indication.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the surgical procedure was performed for a cancer-related indication.","meaning":"Boolean indicating whether the surgical procedure was performed for a cancer-related indication."} // "procedure code for cancer-related surgery (during the index hospitalization)"

;; ===================== Auxiliary Assertions (REQ 2) =====================
;; Qualifier variable for cancer-related indication implies surgical procedure occurred
(assert
  (! (=> patient_has_undergone_surgical_procedure_now@@cancer_related_indication
         patient_has_undergone_surgical_procedure_now)
     :named REQ2_AUXILIARY0)) ;; "procedure code for cancer-related surgery (during the index hospitalization)"

;; ===================== Constraint Assertions (REQ 2) =====================
(assert
  (! patient_has_undergone_surgical_procedure_now@@cancer_related_indication
     :named REQ2_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "procedure code for cancer-related surgery (during the index hospitalization)"

