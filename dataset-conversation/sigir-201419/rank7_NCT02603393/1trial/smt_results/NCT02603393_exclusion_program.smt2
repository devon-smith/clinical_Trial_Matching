;; ===================== Declarations for the exclusion criterion (REQ 0) =====================
(declare-const spirometry_acceptability_result_at_visit_101 Bool) ;; {"when_to_set_to_true":"Set to true if the spirometry performed at Visit 101 achieved acceptable results according to American Thoracic Society or European Respiratory Society criteria.","when_to_set_to_false":"Set to false if the spirometry performed at Visit 101 did not achieve acceptable results according to American Thoracic Society or European Respiratory Society criteria.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the spirometry performed at Visit 101 achieved acceptable results according to American Thoracic Society or European Respiratory Society criteria.","meaning":"Boolean indicating whether the spirometry performed at Visit 101 achieved acceptable results according to American Thoracic Society or European Respiratory Society criteria."} ;; "acceptable spirometry results at Visit 101 in accordance with American Thoracic Society criteria for acceptability or European Respiratory Society criteria for acceptability"

(declare-const spirometry_performed_at_visit_101 Bool) ;; {"when_to_set_to_true":"Set to true if spirometry was performed at Visit 101.","when_to_set_to_false":"Set to false if spirometry was not performed at Visit 101.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether spirometry was performed at Visit 101.","meaning":"Boolean indicating whether spirometry was performed at Visit 101."} ;; "spirometry performed at Visit 101"

(declare-const spirometry_performed_at_visit_101@@performed_in_accordance_with_ats_or_ers_acceptability_criteria Bool) ;; {"when_to_set_to_true":"Set to true if spirometry performed at Visit 101 was conducted in accordance with American Thoracic Society or European Respiratory Society criteria for acceptability.","when_to_set_to_false":"Set to false if spirometry performed at Visit 101 was not conducted in accordance with American Thoracic Society or European Respiratory Society criteria for acceptability.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether spirometry performed at Visit 101 was conducted in accordance with American Thoracic Society or European Respiratory Society criteria for acceptability.","meaning":"Boolean indicating whether spirometry performed at Visit 101 was conducted in accordance with American Thoracic Society or European Respiratory Society criteria for acceptability."} ;; "spirometry performed at Visit 101 in accordance with American Thoracic Society or European Respiratory Society criteria for acceptability"

(declare-const spirometry_retest_performed_at_visit_101 Bool) ;; {"when_to_set_to_true":"Set to true if a retest of spirometry was performed at Visit 101 for patients who did not meet acceptability criteria on the initial test.","when_to_set_to_false":"Set to false if a retest of spirometry was not performed at Visit 101 for patients who did not meet acceptability criteria on the initial test.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether a retest of spirometry was performed at Visit 101 for patients who did not meet acceptability criteria on the initial test.","meaning":"Boolean indicating whether a retest of spirometry was performed at Visit 101 for patients who did not meet acceptability criteria on the initial test."} ;; "one retest may be performed for patients that do not meet the acceptability criteria"

;; ===================== Auxiliary Assertions (REQ 0) =====================
;; Qualifier variable implies corresponding stem variable
(assert
(! (=> spirometry_performed_at_visit_101@@performed_in_accordance_with_ats_or_ers_acceptability_criteria
      spirometry_performed_at_visit_101)
:named REQ0_AUXILIARY0)) ;; "spirometry performed at Visit 101 in accordance with American Thoracic Society or European Respiratory Society criteria for acceptability"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Exclusion: patient must NOT have failed to achieve acceptable spirometry results at Visit 101 (including after one retest if performed)
(assert
(! (not spirometry_acceptability_result_at_visit_101)
:named REQ0_COMPONENT0_CAN_ALWAYS_GO_FROM_SATISFIED_TO_NOTSATISFIED)) ;; "A patient is excluded if the patient has not achieved acceptable spirometry results at Visit 101 in accordance with American Thoracic Society criteria for acceptability or European Respiratory Society criteria for acceptability (one retest may be performed for patients that do not meet the acceptability criteria)."

;; ===================== Declarations for the exclusion criterion (REQ 1) =====================
(declare-const patient_acute_exacerbation_of_chronic_obstructive_airways_disease_value_recorded_inthepast1years_withunit_count Real) ;; {"when_to_set_to_value":"Set to the number of acute exacerbations of chronic obstructive airways disease (COPD exacerbations) the patient experienced in the last 1 year prior to Visit 1, as defined by qualifying criteria (each requiring antibiotics, oral corticosteroids, or hospitalization).","when_to_set_to_null":"Set to null if the number of qualifying COPD exacerbations in the last year prior to Visit 1 is unknown, not documented, or cannot be determined.","meaning":"Numeric count of qualifying acute exacerbations of chronic obstructive airways disease in the last year prior to Visit 1."} ;; "chronic obstructive pulmonary disease exacerbation in the last year prior to Visit 1"

(declare-const patient_acute_exacerbation_of_chronic_obstructive_airways_disease_value_recorded_inthepast1years_withunit_count@@each_exacerbation_required_antibiotics_or_oral_corticosteroids_or_hospitalization Bool) ;; {"when_to_set_to_true":"Set to true if each counted COPD exacerbation in the last year prior to Visit 1 required treatment with antibiotics OR oral corticosteroids OR hospitalization.","when_to_set_to_false":"Set to false if any counted COPD exacerbation did not meet the qualifying treatment/hospitalization criteria.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether each counted exacerbation met the qualifying criteria.","meaning":"Boolean indicating whether each counted COPD exacerbation in the last year prior to Visit 1 met the qualifying treatment/hospitalization criteria."} ;; "where each exacerbation required treatment with antibiotics OR required treatment with oral corticosteroids OR required hospitalization"

;; ===================== Constraint Assertions (REQ 1) =====================
(assert
(! (not (and
           (> patient_acute_exacerbation_of_chronic_obstructive_airways_disease_value_recorded_inthepast1years_withunit_count 1)
           patient_acute_exacerbation_of_chronic_obstructive_airways_disease_value_recorded_inthepast1years_withunit_count@@each_exacerbation_required_antibiotics_or_oral_corticosteroids_or_hospitalization))
   :named REQ1_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient has had more than one chronic obstructive pulmonary disease exacerbation (where each exacerbation required treatment with antibiotics OR required treatment with oral corticosteroids OR required hospitalization) in the last year prior to Visit 1."

;; ===================== Declarations for the exclusion criterion (REQ 2) =====================
(declare-const patient_has_finding_of_acute_exacerbation_of_chronic_obstructive_airways_disease_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever had an acute exacerbation of chronic obstructive airways disease at any time in the past.","when_to_set_to_false":"Set to false if the patient has never had an acute exacerbation of chronic obstructive airways disease at any time in the past.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever had an acute exacerbation of chronic obstructive airways disease.","meaning":"Boolean indicating whether the patient has ever had an acute exacerbation of chronic obstructive airways disease in the past."} ;; "chronic obstructive pulmonary disease exacerbation"
(declare-const patient_has_finding_of_acute_exacerbation_of_chronic_obstructive_airways_disease_inthehistory@@temporalcontext_within6weeks_before_screening_visit1_or_between_screening_visit1_and_treatment_visit201 Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever had an acute exacerbation of chronic obstructive airways disease within six weeks before screening (Visit 1) or between screening (Visit 1) and treatment (Visit 201).","when_to_set_to_false":"Set to false if the patient has never had an acute exacerbation of chronic obstructive airways disease within those windows.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient had an acute exacerbation of chronic obstructive airways disease within those windows.","meaning":"Boolean indicating whether the patient had an acute exacerbation of chronic obstructive airways disease within six weeks before screening (Visit 1) or between screening (Visit 1) and treatment (Visit 201)."} ;; "chronic obstructive pulmonary disease exacerbation of any severity within six weeks before screening (Visit 1) OR between screening (Visit 1) and treatment (Visit 201)"

;; ===================== Auxiliary Assertions (REQ 2) =====================
;; Qualifier variable implies corresponding stem variable
(assert
(! (=> patient_has_finding_of_acute_exacerbation_of_chronic_obstructive_airways_disease_inthehistory@@temporalcontext_within6weeks_before_screening_visit1_or_between_screening_visit1_and_treatment_visit201
      patient_has_finding_of_acute_exacerbation_of_chronic_obstructive_airways_disease_inthehistory)
:named REQ2_AUXILIARY0)) ;; "chronic obstructive pulmonary disease exacerbation of any severity within six weeks before screening (Visit 1) OR between screening (Visit 1) and treatment (Visit 201)"

;; ===================== Constraint Assertions (REQ 2) =====================
(assert
(! (not patient_has_finding_of_acute_exacerbation_of_chronic_obstructive_airways_disease_inthehistory@@temporalcontext_within6weeks_before_screening_visit1_or_between_screening_visit1_and_treatment_visit201)
:named REQ2_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient developed a chronic obstructive pulmonary disease exacerbation of any severity within six weeks before screening (Visit 1) OR between screening (Visit 1) and treatment (Visit 201)."

;; ===================== Declarations for the exclusion criterion (REQ 3) =====================
(declare-const patient_meets_other_protocol_defined_exclusion_criteria Bool) ;; {"when_to_set_to_true":"Set to true if the patient meets any other protocol-defined exclusion criteria not otherwise specified.","when_to_set_to_false":"Set to false if the patient does not meet any other protocol-defined exclusion criteria not otherwise specified.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient meets any other protocol-defined exclusion criteria.","meaning":"Boolean indicating whether the patient meets any other protocol-defined exclusion criteria not otherwise specified."} ;; "The patient is excluded if the patient meets other protocol-defined exclusion criteria."

;; ===================== Constraint Assertions (REQ 3) =====================
(assert
(! (not patient_meets_other_protocol_defined_exclusion_criteria)
:named REQ3_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient meets other protocol-defined exclusion criteria."
