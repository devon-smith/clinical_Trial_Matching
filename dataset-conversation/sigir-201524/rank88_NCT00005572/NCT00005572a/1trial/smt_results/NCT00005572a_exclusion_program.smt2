(! (not (and
  (or patient_is_exposed_to_drug_or_medicament_inthepast30days@@might_affect_immune_system
      patient_is_exposed_to_drug_or_medicament_inthefuture@@might_affect_immune_system)
  (not (or patient_is_taking_prednisone_containing_product_now@@for_patients_with_pneumocystis_carinii_pneumonia
           patient_is_exposed_to_colony_stimulating_factor_granulocyte_macrophage_inthefuture))))
:named REQ1_COMPONENT2_CAN_ALWAYS_GO_FROM_SATISFIED_TO_NOTSATISFIED)) ;; "has taken any drug that might affect the immune system within 30 days of study entry or plans to take any drug that might affect the immune system during the study, except for prednisone for patients with Pneumocystis carinii pneumonia and granulocyte colony-stimulating factor."

