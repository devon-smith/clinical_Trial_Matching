  (or patient_is_exposed_to_drug_or_medicament_inthepast30days@@is_investigational
      patient_is_exposed_to_drug_or_medicament_inthefuture@@is_investigational)
  (not (or patient_is_taking_prednisone_containing_product_now@@for_patients_with_pneumocystis_carinii_pneumonia
