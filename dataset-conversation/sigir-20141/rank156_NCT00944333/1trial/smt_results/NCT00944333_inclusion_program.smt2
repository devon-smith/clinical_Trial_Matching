(declare-const patient_has_diagnosis_of_silent_myocardial_ischemia_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has a diagnosis of silent myocardial ischemia.","when_to_set_to_false":"Set to false if the patient currently does not have a diagnosis of silent myocardial ischemia.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has a diagnosis of silent myocardial ischemia.","meaning":"Boolean indicating whether the patient currently has a diagnosis of silent myocardial ischemia."} // "documented silent ischemia"
