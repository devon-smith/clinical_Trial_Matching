(declare-const patient_is_taking_second_generation_drug_eluting_stent_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently being treated with a second generation drug eluting stent.","when_to_set_to_false":"Set to false if the patient is currently not being treated with a second generation drug eluting stent.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently being treated with a second generation drug eluting stent.","meaning":"Boolean indicating whether the patient is currently being treated with a second generation drug eluting stent."} // "second generation drug eluting stent"

;; ===================== Auxiliary Assertions (REQ 0) =====================
;; CCS classification defines angina pectoris diagnosis (exhaustive: I, II, III, IV)
(assert
  (! (= patient_has_diagnosis_of_angina_pectoris_now
        (or patient_has_diagnosis_of_angina_pectoris_now_classified_by_ccs_class_i
            patient_has_diagnosis_of_angina_pectoris_now_classified_by_ccs_class_ii
            patient_has_diagnosis_of_angina_pectoris_now_classified_by_ccs_class_iii
            patient_has_diagnosis_of_angina_pectoris_now_classified_by_ccs_class_iv))
     :named REQ0_AUXILIARY0)) ;; "as defined by Canadian Cardiovascular Society Classification (Class I OR Class II OR Class III OR Class IV)"

;; Braunwald classification for unstable angina pectoris (exhaustive: Type B or Type C AND Severity I, II, III)
(assert
  (! (= patient_has_diagnosis_of_preinfarction_syndrome_now
        (or
          (and patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_type_b
               (or patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_severity_i
                   patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_severity_ii
                   patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_severity_iii))
          (and patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_type_c
               (or patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_severity_i
                   patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_severity_ii
                   patient_has_diagnosis_of_preinfarction_syndrome_now_classified_by_braunwald_severity_iii))))
     :named REQ0_AUXILIARY1)) ;; "as defined by Braunwald Classification (Type B OR Type C) AND (Severity I OR Severity II OR Severity III)"

;; Second generation drug eluting stent is a subclass of drug eluting stent
(assert
  (! (=> patient_is_taking_second_generation_drug_eluting_stent_now
         patient_is_taking_drug_eluting_stent_now)
     :named REQ0_AUXILIARY2)) ;; "be treated with a second generation drug eluting stent"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: Diagnosis requirement
(assert
  (! (or patient_has_diagnosis_of_angina_pectoris_now
         patient_has_diagnosis_of_preinfarction_syndrome_now
         patient_has_diagnosis_of_silent_myocardial_ischemia_now)
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "((have a diagnosis of angina pectoris ...) OR (have a diagnosis of unstable angina pectoris ...) OR (have a diagnosis of documented silent ischemia))"

;; Component 1: Second generation drug eluting stent requirement
(assert
  (! patient_is_taking_second_generation_drug_eluting_stent_now
     :named REQ0_COMPONENT1_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "be treated with a second generation drug eluting stent"

;; ===================== Declarations for the inclusion criterion (REQ 1) =====================
(declare-const patient_has_finding_of_stricture_of_artery_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has a clinical finding of stricture (stenosis) of an artery.","when_to_set_to_false":"Set to false if the patient currently does not have a clinical finding of stricture (stenosis) of an artery.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has a clinical finding of stricture (stenosis) of an artery.","meaning":"Boolean indicating whether the patient currently has a stricture (stenosis) of an artery."} // "de novo stenosis in a native coronary artery"
(declare-const patient_has_finding_of_stricture_of_artery_now@@is_de_novo Bool) ;; {"when_to_set_to_true":"Set to true if the patient's current stricture (stenosis) of an artery is de novo.","when_to_set_to_false":"Set to false if the patient's current stricture (stenosis) of an artery is not de novo.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's current stricture (stenosis) of an artery is de novo.","meaning":"Boolean indicating whether the patient's current stricture (stenosis) of an artery is de novo."} // "de novo"
(declare-const patient_has_finding_of_stricture_of_artery_now@@located_in_native_coronary_artery Bool) ;; {"when_to_set_to_true":"Set to true if the patient's current stricture (stenosis) of an artery is located in a native coronary artery.","when_to_set_to_false":"Set to false if the patient's current stricture (stenosis) of an artery is not located in a native coronary artery.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's current stricture (stenosis) of an artery is located in a native coronary artery.","meaning":"Boolean indicating whether the patient's current stricture (stenosis) of an artery is located in a native coronary artery."} // "native coronary artery"
(declare-const patient_stricture_of_artery_value_recorded_now_withunit_percent Real) ;; {"when_to_set_to_value":"Set to the measured percentage value if a numeric measurement of the percentage of stricture (stenosis) of an artery recorded now is available.","when_to_set_to_null":"Set to null if no such percentage measurement recorded now is available or the value is indeterminate.","meaning":"Numeric percentage representing the patient's current degree of stricture (stenosis) of an artery."} // "stenosis percentage ≥ 70%"
(declare-const patient_is_taking_second_generation_drug_eluting_stent_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently being treated with a second generation drug eluting stent.","when_to_set_to_false":"Set to false if the patient is currently not being treated with a second generation drug eluting stent.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently being treated with a second generation drug eluting stent.","meaning":"Boolean indicating whether the patient is currently being treated with a second generation drug eluting stent."} // "second generation drug eluting stent"
(declare-const patient_is_taking_second_generation_drug_eluting_stent_now@@is_resolute_stent Bool) ;; {"when_to_set_to_true":"Set to true if the patient's current second generation drug eluting stent is a Resolute stent.","when_to_set_to_false":"Set to false if the patient's current second generation drug eluting stent is not a Resolute stent.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's current second generation drug eluting stent is a Resolute stent.","meaning":"Boolean indicating whether the patient's current second generation drug eluting stent is a Resolute stent."} // "Resolute drug eluting stent"

;; ===================== Auxiliary Assertions (REQ 1) =====================
;; Qualifier variables imply corresponding stem variables
(assert
  (! (=> patient_has_finding_of_stricture_of_artery_now@@is_de_novo
         patient_has_finding_of_stricture_of_artery_now)
     :named REQ1_AUXILIARY0)) ;; "de novo stenosis"

(assert
  (! (=> patient_has_finding_of_stricture_of_artery_now@@located_in_native_coronary_artery
         patient_has_finding_of_stricture_of_artery_now)
     :named REQ1_AUXILIARY1)) ;; "native coronary artery"

(assert
  (! (=> patient_is_taking_second_generation_drug_eluting_stent_now@@is_resolute_stent
         patient_is_taking_second_generation_drug_eluting_stent_now)
     :named REQ1_AUXILIARY2)) ;; "Resolute drug eluting stent"

;; ===================== Constraint Assertions (REQ 1) =====================
;; Component 0: At least one de novo stenosis (with stenosis percentage ≥ 70%) in a native coronary artery
(assert
  (! (and patient_has_finding_of_stricture_of_artery_now@@is_de_novo
          patient_has_finding_of_stricture_of_artery_now@@located_in_native_coronary_artery
          (>= patient_stricture_of_artery_value_recorded_now_withunit_percent 70.0))
     :named REQ1_COMPONENT0_OTHER_REQUIREMENTS)) ;; "at least one de novo stenosis (with stenosis percentage ≥ 70%) in a native coronary artery"

;; Component 1: Treated with a Resolute drug eluting stent
(assert
  (! patient_is_taking_second_generation_drug_eluting_stent_now@@is_resolute_stent
     :named REQ1_COMPONENT1_OTHER_REQUIREMENTS)) ;; "treated with a Resolute drug eluting stent"

;; ===================== Declarations for the criterion (REQ 2) =====================
(declare-const minimum_age_value_required_by_local_regulations_in_years Real) ;; {"when_to_set_to_value":"Set to the minimum age in years as specified by local regulations if it is known and documented.","when_to_set_to_null":"Set to null if the minimum age required by local regulations is unknown, not documented, or cannot be determined.","meaning":"Numeric value indicating the minimum age in years as required by local regulations for eligibility."} // "minimum age as required by local regulations"
(declare-const patient_age_value_recorded_now_in_years Real) ;; {"when_to_set_to_value":"Set to the patient's current age in years if it is known and documented.","when_to_set_to_null":"Set to null if the patient's current age in years is unknown, not documented, or cannot be determined.","meaning":"Numeric value indicating the patient's current age in years."} // "older than 18 years of age OR meet the minimum age as required by local regulations"

;; ===================== Constraint Assertions (REQ 2) =====================
(assert
  (! (or (> patient_age_value_recorded_now_in_years 18)
         (>= patient_age_value_recorded_now_in_years minimum_age_value_required_by_local_regulations_in_years))
     :named REQ2_COMPONENT0_OTHER_REQUIREMENTS)) ;; "To be included, the patient must (be older than 18 years of age OR meet the minimum age as required by local regulations)."

;; ===================== Declarations for the criterion (REQ 3) =====================
