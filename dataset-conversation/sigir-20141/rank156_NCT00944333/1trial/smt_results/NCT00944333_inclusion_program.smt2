;; ===================== Declarations for the criterion (REQ 5) =====================
(declare-const patient_has_finding_of_finding_of_lesion_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has any type or number of lesions.","when_to_set_to_false":"Set to false if the patient currently does not have any lesions.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has any lesions.","meaning":"Boolean indicating whether the patient currently has any type or number of lesions."} // "may have any type of lesion AND any number of lesions, unless specifically detailed in the exclusion criteria."

