;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_has_undergone_operation_on_heart_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has at any time in the past undergone a cardiac operation.","when_to_set_to_false":"Set to false if the patient has never undergone a cardiac operation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever undergone a cardiac operation.","meaning":"Boolean indicating whether the patient has at any time in the past undergone a cardiac operation."} // "cardiac operation"
(declare-const patient_has_undergone_coronary_artery_bypass_graft_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has at any time in the past undergone coronary artery bypass grafting.","when_to_set_to_false":"Set to false if the patient has never undergone coronary artery bypass grafting.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever undergone coronary artery bypass grafting.","meaning":"Boolean indicating whether the patient has at any time in the past undergone coronary artery bypass grafting."} // "coronary artery bypass grafting"
(declare-const patient_has_undergone_aortic_valve_replacement_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has at any time in the past undergone aortic valve replacement.","when_to_set_to_false":"Set to false if the patient has never undergone aortic valve replacement.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever undergone aortic valve replacement.","meaning":"Boolean indicating whether the patient has at any time in the past undergone aortic valve replacement."} // "aortic valve replacement"

;; ===================== Constraint Assertions (REQ 0) =====================
(assert
  (! (or patient_has_undergone_operation_on_heart_inthehistory
         patient_has_undergone_coronary_artery_bypass_graft_inthehistory
         patient_has_undergone_aortic_valve_replacement_inthehistory)
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have previously undergone a cardiac operation OR have previously undergone coronary artery bypass grafting OR have previously undergone aortic valve replacement."
