;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_is_presenting_to_emergency_department_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently presenting to the Emergency Department.","when_to_set_to_false":"Set to false if the patient is not currently presenting to the Emergency Department.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently presenting to the Emergency Department.","meaning":"Boolean indicating whether the patient is currently presenting to the Emergency Department."} // "To be included, the patient must be presenting to the Emergency Department."
(declare-const patient_has_finding_of_cough_now@@present_at_time_of_emergency_department_presentation Bool) ;; {"when_to_set_to_true":"Set to true if the patient's cough is present specifically at the time of Emergency Department presentation.","when_to_set_to_false":"Set to false if the patient's cough is not present at the time of Emergency Department presentation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's cough is present at the time of Emergency Department presentation.","meaning":"Boolean indicating whether the patient's cough is present at the time of Emergency Department presentation."} // "presenting with cough"
(declare-const patient_has_finding_of_wheezing_now@@present_at_time_of_emergency_department_presentation Bool) ;; {"when_to_set_to_true":"Set to true if the patient's wheezing is present specifically at the time of Emergency Department presentation.","when_to_set_to_false":"Set to false if the patient's wheezing is not present at the time of Emergency Department presentation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's wheezing is present at the time of Emergency Department presentation.","meaning":"Boolean indicating whether the patient's wheezing is present at the time of Emergency Department presentation."} // "presenting with wheezing"
(declare-const patient_has_finding_of_dyspnea_now@@present_at_time_of_emergency_department_presentation Bool) ;; {"when_to_set_to_true":"Set to true if the patient's dyspnea is present specifically at the time of Emergency Department presentation.","when_to_set_to_false":"Set to false if the patient's dyspnea is not present at the time of Emergency Department presentation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's dyspnea is present at the time of Emergency Department presentation.","meaning":"Boolean indicating whether the patient's dyspnea is present at the time of Emergency Department presentation."} // "presenting with dyspnea"

;; ===================== Constraint Assertions (REQ 0) =====================
(assert
  (! patient_is_presenting_to_emergency_department_now
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must be presenting to the Emergency Department."

(assert
  (! (or patient_has_finding_of_cough_now@@present_at_time_of_emergency_department_presentation
         patient_has_finding_of_wheezing_now@@present_at_time_of_emergency_department_presentation
         patient_has_finding_of_dyspnea_now@@present_at_time_of_emergency_department_presentation)
     :named REQ0_COMPONENT1_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must be presenting with (cough OR wheezing OR dyspnea)."

;; ===================== Declarations for the criterion (REQ 1) =====================
(declare-const patient_is_undergoing_plain_chest_x_ray_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently referred for or undergoing a plain chest x-ray (chest radiograph).","when_to_set_to_false":"Set to false if the patient is not currently referred for or undergoing a plain chest x-ray (chest radiograph).","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently referred for or undergoing a plain chest x-ray (chest radiograph).","meaning":"Boolean indicating whether the patient is currently referred for or undergoing a plain chest x-ray (chest radiograph)."} // "referred for chest radiograph"
(declare-const patient_is_undergoing_computerized_axial_tomography_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently referred for or undergoing a computerized axial tomography scan (computed tomography scan).","when_to_set_to_false":"Set to false if the patient is not currently referred for or undergoing a computerized axial tomography scan (computed tomography scan).","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently referred for or undergoing a computerized axial tomography scan (computed tomography scan).","meaning":"Boolean indicating whether the patient is currently referred for or undergoing a computerized axial tomography scan (computed tomography scan)."} // "referred for computed tomography scan"

;; ===================== Constraint Assertions (REQ 1) =====================
(assert
  (! (or patient_is_undergoing_plain_chest_x_ray_now
         patient_is_undergoing_computerized_axial_tomography_now)
     :named REQ1_COMPONENT0_NOT_REQUIREMNET_OR_ALWAYS_SATISFIABLE_WITH_ACTION)) ;; "To be included, the patient must be (referred for chest radiograph OR referred for computed tomography scan)."
