;; ===================== Auxiliary Assertions (REQ 0) =====================
;; Qualifier variable for tablet size implies discontinuation
(assert
  (! (=> patient_has_discontinued_standard_vitamin_supplementation_now@@reason_for_discontinuation_is_tablet_size
         patient_has_discontinued_standard_vitamin_supplementation_now)
     :named REQ0_AUXILIARY0)) ;; "have discontinued her standard vitamin supplementation due to tablet size"

;; Qualifier variable for GI symptom as reason implies both GI symptom and discontinuation
(assert
  (! (=> patient_has_finding_of_gastrointestinal_symptom_now@@reason_for_discontinuation_of_standard_vitamin_supplementation
         (and patient_has_finding_of_gastrointestinal_symptom_now
              patient_has_discontinued_standard_vitamin_supplementation_now))
     :named REQ0_AUXILIARY1)) ;; "have discontinued her standard vitamin supplementation due to a gastrointestinal symptom"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: patient must be a woman
(assert
  (! patient_sex_is_female_now
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must be a woman."

;; Component 1: patient must have discontinued vitamin supplementation due to GI symptom OR tablet size
(assert
  (! (or patient_has_finding_of_gastrointestinal_symptom_now@@reason_for_discontinuation_of_standard_vitamin_supplementation
         patient_has_discontinued_standard_vitamin_supplementation_now@@reason_for_discontinuation_is_tablet_size)
     :named REQ0_COMPONENT0_OTHER_REQUIREMENTS)) ;; "have discontinued her standard vitamin supplementation due to a gastrointestinal symptom OR have discontinued her standard vitamin supplementation due to tablet size"

;; Component 2: patient must have at least one of the listed conditions
(assert
  (! (or patient_has_finding_of_morning_sickness_now
         patient_has_finding_of_crohns_disease_now
         patient_has_finding_of_ulcerative_colitis_now
         patient_has_finding_of_peptic_ulcer_now
         patient_has_finding_of_duodenal_ulcer_disease_now
         patient_has_finding_of_irritable_bowel_syndrome_now
         patient_has_finding_of_celiac_disease_now
         patient_has_finding_of_iron_deficiency_anemia_now
         patient_has_finding_of_hypothyroidism_now
         patient_has_finding_of_depressive_disorder_now)
     :named REQ0_COMPONENT1_OTHER_REQUIREMENTS)) ;; "have at least one of the following conditions: (morning sickness) OR (Crohn's disease) OR (ulcerative colitis) OR (peptic ulcer) OR (duodenal ulcer) OR (irritable colon) OR (celiac disease) OR (iron deficiency anemia) OR (hypothyroidism) OR (depression)"
