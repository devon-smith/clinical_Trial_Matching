(declare-const patient_has_finding_of_peptic_ulcer_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has peptic ulcer.","when_to_set_to_false":"Set to false if the patient currently does not have peptic ulcer.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has peptic ulcer.","meaning":"Boolean indicating whether the patient currently has peptic ulcer."} ;; "peptic ulcer"
