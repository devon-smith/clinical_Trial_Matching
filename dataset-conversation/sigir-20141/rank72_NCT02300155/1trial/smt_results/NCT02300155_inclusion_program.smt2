(declare-const patient_has_discontinued_standard_vitamin_supplementation_now@@reason_for_discontinuation_is_tablet_size Bool) ;; {"when_to_set_to_true":"Set to true if the reason for discontinuation of standard vitamin supplementation is tablet size.","when_to_set_to_false":"Set to false if the reason for discontinuation of standard vitamin supplementation is not tablet size.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether tablet size is the reason for discontinuation of standard vitamin supplementation.","meaning":"Boolean indicating whether tablet size is the reason for discontinuation of standard vitamin supplementation."} ;; "have discontinued her standard vitamin supplementation due to tablet size"
(declare-const patient_has_finding_of_gastrointestinal_symptom_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has a gastrointestinal symptom.","when_to_set_to_false":"Set to false if the patient currently does not have a gastrointestinal symptom.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has a gastrointestinal symptom.","meaning":"Boolean indicating whether the patient currently has a gastrointestinal symptom."} ;; "have discontinued her standard vitamin supplementation due to a gastrointestinal symptom"
(declare-const patient_has_finding_of_gastrointestinal_symptom_now@@reason_for_discontinuation_of_standard_vitamin_supplementation Bool) ;; {"when_to_set_to_true":"Set to true if the patient's gastrointestinal symptom is the reason for discontinuation of standard vitamin supplementation.","when_to_set_to_false":"Set to false if the patient's gastrointestinal symptom is not the reason for discontinuation of standard vitamin supplementation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the gastrointestinal symptom is the reason for discontinuation of standard vitamin supplementation.","meaning":"Boolean indicating whether the patient's gastrointestinal symptom is the reason for discontinuation of standard vitamin supplementation."} ;; "have discontinued her standard vitamin supplementation due to a gastrointestinal symptom"
(declare-const patient_has_finding_of_morning_sickness_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has morning sickness.","when_to_set_to_false":"Set to false if the patient currently does not have morning sickness.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has morning sickness.","meaning":"Boolean indicating whether the patient currently has morning sickness."} ;; "morning sickness"
