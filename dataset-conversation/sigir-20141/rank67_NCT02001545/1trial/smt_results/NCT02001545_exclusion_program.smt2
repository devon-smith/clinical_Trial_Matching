(declare-const patient_has_psychiatric_disturbances_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has psychiatric disturbances.","when_to_set_to_false":"Set to false if the patient currently does not have psychiatric disturbances.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has psychiatric disturbances.","meaning":"Boolean indicating whether the patient currently has psychiatric disturbances."} ;; "having psychiatric disturbances"

(declare-const patient_has_psychiatric_disturbances_now@@could_significantly_limit_complete_follow_up_investigator_opinion Bool) ;; {"when_to_set_to_true":"Set to true if, in the opinion of the investigator, the patient's current psychiatric disturbances could significantly limit the complete follow-up of the patient.","when_to_set_to_false":"Set to false if, in the opinion of the investigator, the patient's current psychiatric disturbances could not significantly limit the complete follow-up of the patient.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether, in the opinion of the investigator, the patient's current psychiatric disturbances could significantly limit the complete follow-up of the patient.","meaning":"Boolean indicating whether, in the opinion of the investigator, the patient's current psychiatric disturbances could significantly limit the complete follow-up of the patient."} ;; "having psychiatric disturbances which, in the opinion of the investigator, could significantly limit the complete follow-up of the patient"

;; ===================== Auxiliary Assertions (REQ 2) =====================
;; Non-exhaustive examples imply umbrella term
(assert
(! (=> (or patient_is_tourist_now
           patient_is_non_native_speaker_now
           patient_does_not_understand_local_language_now
           patient_has_psychiatric_disturbances_now@@could_significantly_limit_complete_follow_up_investigator_opinion)
    patient_has_condition_limiting_complete_follow_up_investigator_opinion_now)
:named REQ2_AUXILIARY0)) ;; "with non-exhaustive examples ((being a tourist) OR (being a non-native speaker) OR (not understanding the local language) OR (having psychiatric disturbances))."

;; Qualifier variable implies corresponding stem variable
(assert
(! (=> patient_has_psychiatric_disturbances_now@@could_significantly_limit_complete_follow_up_investigator_opinion
    patient_has_psychiatric_disturbances_now)
:named REQ2_AUXILIARY1)) ;; "psychiatric disturbances which, in the opinion of the investigator, could significantly limit the complete follow-up of the patient"

;; ===================== Constraint Assertions (REQ 2) =====================
(assert
(! (not patient_has_condition_limiting_complete_follow_up_investigator_opinion_now)
:named REQ2_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient has any condition OR any circumstance which, in the opinion of the investigator, could significantly limit the complete follow-up of the patient"
