;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_systolic_blood_pressure_value_recorded_now_withunit_millimeters_of_mercury Real) ;; {"when_to_set_to_value":"Set to the measured value if the patient's systolic blood pressure in millimeters of mercury is recorded now.","when_to_set_to_null":"Set to null if no systolic blood pressure measurement in millimeters of mercury is available for now or the value is indeterminate.","meaning":"Numeric value of the patient's current systolic blood pressure in millimeters of mercury."}  ;; "systolic blood pressure"
(declare-const patient_diastolic_blood_pressure_value_recorded_now_withunit_millimeters_of_mercury Real) ;; {"when_to_set_to_value":"Set to the measured value if the patient's diastolic blood pressure in millimeters of mercury is recorded now.","when_to_set_to_null":"Set to null if no diastolic blood pressure measurement in millimeters of mercury is available for now or the value is indeterminate.","meaning":"Numeric value of the patient's current diastolic blood pressure in millimeters of mercury."}  ;; "diastolic blood pressure"
(declare-const patient_is_undergoing_antihypertensive_therapy_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently receiving antihypertensive therapy.","when_to_set_to_false":"Set to false if the patient is currently not receiving antihypertensive therapy.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently receiving antihypertensive therapy.","meaning":"Boolean indicating whether the patient is currently receiving antihypertensive therapy."}  ;; "antihypertensive therapy"

;; ===================== Constraint Assertions (REQ 0) =====================
;; The patient must have systolic blood pressure > 140 mmHg OR diastolic blood pressure > 90 mmHg, regardless of antihypertensive therapy status
(assert
  (! (or
        (> patient_systolic_blood_pressure_value_recorded_now_withunit_millimeters_of_mercury 140.0)
        (> patient_diastolic_blood_pressure_value_recorded_now_withunit_millimeters_of_mercury 90.0)
     )
     :named REQ0_COMPONENT0_OTHER_REQUIREMENTS)) ;; "To be included, the patient must ((have systolic blood pressure > 140 millimeters of mercury) OR (have diastolic blood pressure > 90 millimeters of mercury)), regardless of whether the patient is currently receiving antihypertensive therapy."

;; ===================== Declarations for the criterion (REQ 1) =====================
(declare-const patient_is_undergoing_oral_hypoglycemic_agent_therapy_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently undergoing oral hypoglycemic agent therapy.","when_to_set_to_false":"Set to false if the patient is currently not undergoing oral hypoglycemic agent therapy.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently undergoing oral hypoglycemic agent therapy.","meaning":"Boolean indicating whether the patient is currently undergoing oral hypoglycemic agent therapy."} ;; "regardless of whether the patient uses oral hypoglycemic agent therapy"
(declare-const patient_is_undergoing_subcutaneous_injection_of_insulin_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently undergoing insulin injection therapy.","when_to_set_to_false":"Set to false if the patient is currently not undergoing insulin injection therapy.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently undergoing insulin injection therapy.","meaning":"Boolean indicating whether the patient is currently undergoing insulin injection therapy."} ;; "regardless of whether the patient uses insulin injection therapy"
(declare-const patient_plasma_fasting_glucose_measurement_value_recorded_now_withunit_millimoles_per_liter Real) ;; {"when_to_set_to_value":"Set to the measured value if a fasting plasma glucose measurement in millimoles per liter is recorded now.","when_to_set_to_null":"Set to null if no such measurement is available or the value is indeterminate.","meaning":"Numeric value of the patient's fasting plasma glucose measurement recorded now, in millimoles per liter."} ;; "fasting plasma glucose > 7.0 millimoles per liter"
(declare-const patient_post_prandial_blood_glucose_measurement_value_recorded_now_withunit_millimoles_per_liter Real) ;; {"when_to_set_to_value":"Set to the measured value if a postprandial blood glucose measurement in millimoles per liter is recorded now.","when_to_set_to_null":"Set to null if no such measurement is available or the value is indeterminate.","meaning":"Numeric value of the patient's postprandial blood glucose measurement recorded now, in millimoles per liter."} ;; "postprandial blood glucose > 11.1 millimoles per liter"

(declare-const patient_meets_glucose_criteria_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient has fasting plasma glucose > 7.0 mmol/L or postprandial blood glucose > 11.1 mmol/L, regardless of therapy.","when_to_set_to_false":"Set to false if neither fasting plasma glucose > 7.0 mmol/L nor postprandial blood glucose > 11.1 mmol/L.","when_to_set_to_null":"Set to null if both measurements are unavailable or indeterminate.","meaning":"Boolean indicating whether the patient meets the glucose criteria for inclusion (fasting plasma glucose > 7.0 mmol/L or postprandial blood glucose > 11.1 mmol/L, regardless of therapy)." } ;; "must ((have fasting plasma glucose > 7.0 millimoles per liter) OR (have postprandial blood glucose > 11.1 millimoles per liter)), regardless of whether the patient uses oral hypoglycemic agent therapy OR insulin injection therapy"

;; ===================== Auxiliary Assertions (REQ 1) =====================
;; Definition in the requirement: patient meets glucose criteria if either fasting plasma glucose > 7.0 mmol/L or postprandial blood glucose > 11.1 mmol/L
(assert
  (! (= patient_meets_glucose_criteria_now
        (or (> patient_plasma_fasting_glucose_measurement_value_recorded_now_withunit_millimoles_per_liter 7.0)
            (> patient_post_prandial_blood_glucose_measurement_value_recorded_now_withunit_millimoles_per_liter 11.1)))
     :named REQ1_AUXILIARY0)) ;; "must ((have fasting plasma glucose > 7.0 millimoles per liter) OR (have postprandial blood glucose > 11.1 millimoles per liter)), regardless of whether the patient uses oral hypoglycemic agent therapy OR insulin injection therapy"

;; ===================== Constraint Assertions (REQ 1) =====================
(assert
  (! patient_meets_glucose_criteria_now
     :named REQ1_COMPONENT0_OTHER_REQUIREMENTS)) ;; "To be included, the patient must ((have fasting plasma glucose > 7.0 millimoles per liter) OR (have postprandial blood glucose > 11.1 millimoles per liter)), regardless of whether the patient uses oral hypoglycemic agent therapy OR insulin injection therapy."
