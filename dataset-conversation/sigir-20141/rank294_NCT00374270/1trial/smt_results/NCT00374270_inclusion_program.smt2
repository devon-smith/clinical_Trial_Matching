;; ===================== Auxiliary Assertions (REQ 1) =====================
;; Oral hypoglycemic agent therapy includes all listed drug classes (exhaustive subcategories)
(assert
  (! (= patient_is_undergoing_administration_of_oral_hypoglycemic_agent_therapy_now
        (or patient_is_undergoing_administration_of_alpha_glucosidase_inhibitor_therapy_now
            patient_is_undergoing_administration_of_biguanide_therapy_now
            patient_is_undergoing_administration_of_meglitinide_therapy_now
            patient_is_undergoing_administration_of_sulfonylurea_now
            patient_is_undergoing_administration_of_thiazolidinedione_therapy_now
            patient_is_undergoing_administration_of_adjunctive_therapy_now))
     :named REQ1_AUXILIARY0)) ;; "oral hypoglycemic agent therapy includes drugs in the following classes: ... (exhaustive list)"

;; ===================== Constraint Assertions (REQ 1) =====================
;; Inclusion: patient must be taking oral hypoglycemic agent therapy or insulin therapy for >6 months, and must NOT have steroid-induced or gestational diabetes
(assert
  (! (and
        (or patient_is_undergoing_administration_of_oral_hypoglycemic_agent_therapy_now
            patient_is_undergoing_administration_of_insulin_therapy_now)
        (> duration_of_current_antidiabetic_therapy_in_months 6)
        (not patient_has_diagnosis_of_steroid_induced_diabetes_now)
        (not patient_has_diagnosis_of_gestational_diabetes_now))
     :named REQ1_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have diabetes defined as (presently taking (oral hypoglycemic agent therapy OR insulin therapy) for more than 6 months)... Patients with steroid-induced diabetes or gestational diabetes are not included."
