(declare-const patient_is_undergoing_administration_of_sulfonylurea_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently undergoing administration of sulfonylurea therapy.","when_to_set_to_false":"Set to false if the patient is currently not undergoing administration of sulfonylurea therapy.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently undergoing administration of sulfonylurea therapy.","meaning":"Boolean indicating whether the patient is currently undergoing administration of sulfonylurea therapy."} // "sulfonylurea therapy"
