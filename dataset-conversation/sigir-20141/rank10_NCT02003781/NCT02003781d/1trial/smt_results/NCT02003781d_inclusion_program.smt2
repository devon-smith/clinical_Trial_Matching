;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const relative_is_first_degree_relative_of_patient_with_acute_myocardial_infarction Bool) ;; {"when_to_set_to_true":"Set to true if the subject is a first-degree relative (parent, sibling, or child) of a patient with a documented history of acute myocardial infarction.","when_to_set_to_false":"Set to false if the subject is not a first-degree relative of a patient with a documented history of acute myocardial infarction.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the subject is a first-degree relative of a patient with a documented history of acute myocardial infarction.","meaning":"Boolean indicating whether the subject is a first-degree relative of a patient with a history of acute myocardial infarction."} ;; "To be included, the patient must be a relative of a patient with acute myocardial infarction"
(declare-const patient_has_finding_of_acute_myocardial_infarction_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the index patient has ever had an acute myocardial infarction at any time in their history.","when_to_set_to_false":"Set to false if the index patient has never had an acute myocardial infarction at any time in their history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the index patient has ever had an acute myocardial infarction.","meaning":"Boolean indicating whether the index patient has ever had an acute myocardial infarction in their history."} ;; "acute myocardial infarction"
(declare-const patient_sex_is_male_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient with acute myocardial infarction is documented as male at the current time.","when_to_set_to_false":"Set to false if the patient with acute myocardial infarction is documented as not male at the current time.","when_to_set_to_null":"Set to null if the sex of the patient with acute myocardial infarction is unknown or not documented at the current time.","meaning":"Indicates whether the patient with acute myocardial infarction is male at the current time."} ;; "if the patient with acute myocardial infarction is male"
(declare-const patient_sex_is_female_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient with acute myocardial infarction is documented as female at the current time.","when_to_set_to_false":"Set to false if the patient with acute myocardial infarction is documented as not female at the current time.","when_to_set_to_null":"Set to null if the sex of the patient with acute myocardial infarction is unknown or not documented at the current time.","meaning":"Indicates whether the patient with acute myocardial infarction is female at the current time."} ;; "if the patient with acute myocardial infarction is female"
(declare-const patient_age_value_recorded_inthehistory_in_years Real) ;; {"when_to_set_to_value":"Set to the age in years of the patient with acute myocardial infarction at the time the acute myocardial infarction occurred, if known and documented.","when_to_set_to_null":"Set to null if the age in years at the time of acute myocardial infarction is unknown, not documented, or cannot be determined.","meaning":"Numeric value indicating the age in years of the patient with acute myocardial infarction at the time the acute myocardial infarction occurred."} ;; "age of the patient with acute myocardial infarction at the time of acute myocardial infarction"

;; ===================== Constraint Assertions (REQ 0) =====================
(assert
  (! (and
        relative_is_first_degree_relative_of_patient_with_acute_myocardial_infarction
        patient_has_finding_of_acute_myocardial_infarction_inthehistory
        (or
          (and patient_sex_is_male_now (< patient_age_value_recorded_inthehistory_in_years 55))
          (and patient_sex_is_female_now (< patient_age_value_recorded_inthehistory_in_years 65))
        )
     )
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must be a relative of a patient with acute myocardial infarction (where, if the patient with acute myocardial infarction is male, the age of the patient with acute myocardial infarction at the time of acute myocardial infarction is < 55 years OR if the patient with acute myocardial infarction is female, the age of the patient with acute myocardial infarction at the time of acute myocardial infarction is < 65 years)."
