;; ===================== Declarations for the criterion (REQ 2) =====================
(declare-const patient_is_exposed_to_heparin_inthehistory@@temporalcontext_before_initial_blood_sample Bool) ;; {"when_to_set_to_true":"Set to true if the patient's exposure to heparin occurred before the initial blood sample was taken.","when_to_set_to_false":"Set to false if the patient's exposure to heparin did not occur before the initial blood sample (i.e., occurred after or at the time of the initial blood sample).","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the exposure occurred before the initial blood sample.","meaning":"Boolean indicating whether the patient's exposure to heparin occurred before the initial blood sample."} // "must not have received heparin before the initial blood sample"
(declare-const patient_is_exposed_to_low_molecular_weight_heparin_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever been exposed to low molecular weight heparin at any time in the past, regardless of timing.","when_to_set_to_false":"Set to false if the patient has never been exposed to low molecular weight heparin at any time in the past.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been exposed to low molecular weight heparin.","meaning":"Boolean indicating whether the patient has ever been exposed to low molecular weight heparin in the past."} // "low molecular weight heparin"
(declare-const patient_is_exposed_to_low_molecular_weight_heparin_inthehistory@@temporalcontext_before_initial_blood_sample Bool) ;; {"when_to_set_to_true":"Set to true if the patient's exposure to low molecular weight heparin occurred before the initial blood sample was taken.","when_to_set_to_false":"Set to false if the patient's exposure to low molecular weight heparin did not occur before the initial blood sample (i.e., occurred after or at the time of the initial blood sample).","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the exposure occurred before the initial blood sample.","meaning":"Boolean indicating whether the patient's exposure to low molecular weight heparin occurred before the initial blood sample."} // "must not have received low molecular weight heparin before the initial blood sample"

;; ===================== Auxiliary Assertions (REQ 2) =====================
;; Qualifier variable implies corresponding stem variable for low molecular weight heparin
(assert
  (! (=> patient_is_exposed_to_low_molecular_weight_heparin_inthehistory@@temporalcontext_before_initial_blood_sample
         patient_is_exposed_to_low_molecular_weight_heparin_inthehistory)
     :named REQ2_AUXILIARY0)) ;; "exposure to low molecular weight heparin before the initial blood sample" implies "exposure to low molecular weight heparin in history"

;; ===================== Constraint Assertions (REQ 2) =====================
;; Component 0: Patient must NOT have received heparin or low molecular weight heparin before the initial blood sample
(assert
  (! (and (not patient_is_exposed_to_heparin_inthehistory@@temporalcontext_before_initial_blood_sample)
          (not patient_is_exposed_to_low_molecular_weight_heparin_inthehistory@@temporalcontext_before_initial_blood_sample))
     :named REQ2_COMPONENT0_OTHER_REQUIREMENTS)) ;; "must not have received heparin or low molecular weight heparin before the initial blood sample"

