;; ===================== Auxiliary Assertions (REQ 0) =====================
;; Non-exhaustive examples: listed symptoms are examples of symptoms compatible with acute coronary syndrome
(assert
  (! (=> (or patient_has_symptoms_of_discomfort_now
            patient_has_symptoms_of_tightness_sensation_now
            patient_has_symptoms_of_chest_pain_now
            patient_has_symptoms_of_pain_radiating_to_left_arm_now
            patient_has_symptoms_of_bilateral_pain_in_upper_arms_now
            patient_has_symptoms_of_jaw_pain_now
            patient_has_symptoms_of_backache_now
            patient_has_symptoms_of_neck_pain_now
            patient_has_symptoms_of_stomach_ache_now
            patient_has_symptoms_of_dyspnea_now
            patient_has_symptoms_of_cold_sweat_now
            patient_has_symptoms_of_nausea_now
            patient_has_symptoms_of_vomiting_now
            patient_has_symptoms_of_dizziness_now)
        patient_has_symptoms_of_acute_coronary_syndrome_now)
     :named REQ0_AUXILIARY0)) ;; "e.g., discomfort, tightness or chest pain, pain radiating to the left arm or pain radiating to both arms, pain in the jaw, pain in the back, pain in the neck, pain in the stomach, breathlessness, cold sweats, nausea, vomiting, or dizziness"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: must have symptoms compatible with acute coronary syndrome, for at least 15 minutes and not older than 3 hours
(assert
  (! (and patient_has_symptoms_of_acute_coronary_syndrome_now
          (>= patient_symptom_duration_value_recorded_now_in_minutes 15.0)
          (<= patient_symptom_onset_time_value_recorded_now_in_minutes_ago 180.0))
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "must have symptoms compatible with acute coronary syndrome, for at least 15 minutes and not older than 3 hours"

