;; ===================== Declarations for the inclusion criterion (REQ 0) =====================
(declare-const patient_has_undergone_percutaneous_coronary_intervention_inthehistory_outcome_is_positive@@is_primary Bool) ;; {"when_to_set_to_true":"Set to true if the patient has undergone percutaneous coronary intervention in the past with a positive outcome, and the procedure was primary.","when_to_set_to_false":"Set to false if the patient has undergone percutaneous coronary intervention in the past with a positive outcome, and the procedure was not primary, or if the patient has not undergone the procedure.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has undergone percutaneous coronary intervention in the past with a positive outcome and the procedure was primary.","meaning":"Boolean indicating whether the patient has undergone percutaneous coronary intervention in the past with a positive outcome, and the procedure was primary."} ;; "successful primary percutaneous coronary intervention"
(declare-const patient_has_finding_of_timi_grade_2_partial_perfusion_inthehistory@@result_of_percutaneous_coronary_intervention Bool) ;; {"when_to_set_to_true":"Set to true if the TIMI grade 2 partial perfusion is the result of percutaneous coronary intervention.","when_to_set_to_false":"Set to false if the TIMI grade 2 partial perfusion is not the result of percutaneous coronary intervention.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the TIMI grade 2 partial perfusion is the result of percutaneous coronary intervention.","meaning":"Boolean indicating whether the TIMI grade 2 partial perfusion is the result of percutaneous coronary intervention."} ;; "Thrombolysis In Myocardial Infarction (TIMI) grade 2 flow"
(declare-const patient_has_finding_of_timi_grade_3_normal_flow_inthehistory@@result_of_percutaneous_coronary_intervention Bool) ;; {"when_to_set_to_true":"Set to true if the TIMI grade 3 normal flow is the result of percutaneous coronary intervention.","when_to_set_to_false":"Set to false if the TIMI grade 3 normal flow is not the result of percutaneous coronary intervention.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the TIMI grade 3 normal flow is the result of percutaneous coronary intervention.","meaning":"Boolean indicating whether the TIMI grade 3 normal flow is the result of percutaneous coronary intervention."} ;; "Thrombolysis In Myocardial Infarction (TIMI) grade 3 flow"
(declare-const patient_has_finding_of_acute_myocardial_infarction_inthehistory@@is_first_occurrence Bool) ;; {"when_to_set_to_true":"Set to true if the acute myocardial infarction is the first occurrence for the patient.","when_to_set_to_false":"Set to false if the acute myocardial infarction is not the first occurrence for the patient.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the acute myocardial infarction is the first occurrence.","meaning":"Boolean indicating whether the acute myocardial infarction is the first occurrence."} ;; "first acute myocardial infarction"
(declare-const patient_has_finding_of_acute_myocardial_infarction_inthehistory@@diagnosed_by_chest_pain_suggestive_of_acute_myocardial_infarction Bool) ;; {"when_to_set_to_true":"Set to true if the diagnosis of acute myocardial infarction was made by chest pain suggestive of acute myocardial infarction.","when_to_set_to_false":"Set to false if the diagnosis was not made by chest pain suggestive of acute myocardial infarction.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the diagnosis was made by chest pain suggestive of acute myocardial infarction.","meaning":"Boolean indicating whether the diagnosis of acute myocardial infarction was made by chest pain suggestive of acute myocardial infarction."} ;; "diagnosed by chest pain suggestive of acute myocardial infarction"
(declare-const patient_has_finding_of_acute_myocardial_infarction_inthehistory@@diagnosed_by_symptom_onset_less_than_12_hours_before_hospital_admission_or_less_than_24_hours_in_case_of_ongoing_myocardial_ischemia Bool) ;; {"when_to_set_to_true":"Set to true if the diagnosis of acute myocardial infarction was made by symptom onset less than 12 hours before hospital admission, or less than 24 hours in case of ongoing myocardial ischemia.","when_to_set_to_false":"Set to false if the diagnosis was not made by these criteria.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the diagnosis was made by these criteria.","meaning":"Boolean indicating whether the diagnosis of acute myocardial infarction was made by symptom onset less than 12 hours before hospital admission, or less than 24 hours in case of ongoing myocardial ischemia."} ;; "symptom onset less than 12 hours before hospital admission (or less than 24 hours in case of ongoing myocardial ischemia)"
(declare-const patient_has_finding_of_acute_myocardial_infarction_inthehistory@@diagnosed_by_electrocardiogram_showing_stt_segment_elevation_greater_than_1_mv_in_2_or_more_leads Bool) ;; {"when_to_set_to_true":"Set to true if the diagnosis of acute myocardial infarction was made by electrocardiogram showing ST-T segment elevation greater than 1 mV in 2 or more leads.","when_to_set_to_false":"Set to false if the diagnosis was not made by this criterion.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the diagnosis was made by this criterion.","meaning":"Boolean indicating whether the diagnosis of acute myocardial infarction was made by electrocardiogram showing ST-T segment elevation greater than 1 mV in 2 or more leads."} ;; "electrocardiogram showing ST-T segment elevation greater than 1 mV in 2 or more leads"
(declare-const patient_has_finding_of_timi_grade_0_no_perfusion_inthepast1days@@present_before_primary_percutaneous_coronary_intervention_on_diagnostic_coronary_angiography Bool) ;; {"when_to_set_to_true":"Set to true if the TIMI grade 0 no perfusion was present before primary percutaneous coronary intervention on diagnostic coronary angiography.","when_to_set_to_false":"Set to false if the TIMI grade 0 no perfusion was not present before primary percutaneous coronary intervention on diagnostic coronary angiography.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the TIMI grade 0 no perfusion was present before primary percutaneous coronary intervention on diagnostic coronary angiography.","meaning":"Boolean indicating whether the TIMI grade 0 no perfusion was present before primary percutaneous coronary intervention on diagnostic coronary angiography."} ;; "Thrombolysis In Myocardial Infarction (TIMI) grade 0 flow before primary percutaneous coronary intervention on diagnostic coronary angiography"
(declare-const patient_has_finding_of_timi_grade_1_penetration_without_perfusion_inthepast1days@@present_before_primary_percutaneous_coronary_intervention_on_diagnostic_coronary_angiography Bool) ;; {"when_to_set_to_true":"Set to true if the TIMI grade 1 penetration without perfusion was present before primary percutaneous coronary intervention on diagnostic coronary angiography.","when_to_set_to_false":"Set to false if the TIMI grade 1 penetration without perfusion was not present before primary percutaneous coronary intervention on diagnostic coronary angiography.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the TIMI grade 1 penetration without perfusion was present before primary percutaneous coronary intervention on diagnostic coronary angiography.","meaning":"Boolean indicating whether the TIMI grade 1 penetration without perfusion was present before primary percutaneous coronary intervention on diagnostic coronary angiography."} ;; "Thrombolysis In Myocardial Infarction (TIMI) grade 1 flow before primary percutaneous coronary intervention on diagnostic coronary angiography"

;; ===================== Auxiliary Assertions (REQ 0) =====================
;; TIMI grade 2 or 3 flow as result of PCI defines successful primary PCI
(assert
  (! (= patient_has_undergone_percutaneous_coronary_intervention_inthehistory_outcome_is_positive@@is_primary
        (or patient_has_finding_of_timi_grade_2_partial_perfusion_inthehistory@@result_of_percutaneous_coronary_intervention
            patient_has_finding_of_timi_grade_3_normal_flow_inthehistory@@result_of_percutaneous_coronary_intervention))
     :named REQ0_AUXILIARY0)) ;; "successful primary percutaneous coronary intervention (Thrombolysis In Myocardial Infarction (TIMI) grade 2 flow or Thrombolysis In Myocardial Infarction (TIMI) grade 3 flow)"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: Successful primary PCI (TIMI 2 or 3 flow)
(assert
  (! patient_has_undergone_percutaneous_coronary_intervention_inthehistory_outcome_is_positive@@is_primary
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have had a successful primary percutaneous coronary intervention (Thrombolysis In Myocardial Infarction (TIMI) grade 2 flow or Thrombolysis In Myocardial Infarction (TIMI) grade 3 flow)."

;; Component 1: First acute myocardial infarction
(assert
  (! patient_has_finding_of_acute_myocardial_infarction_inthehistory@@is_first_occurrence
     :named REQ0_COMPONENT1_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have had a first acute myocardial infarction."

;; Component 2: Diagnosed by chest pain suggestive of acute myocardial infarction
(assert
  (! patient_has_finding_of_acute_myocardial_infarction_inthehistory@@diagnosed_by_chest_pain_suggestive_of_acute_myocardial_infarction
     :named REQ0_COMPONENT2_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have had chest pain suggestive of acute myocardial infarction."

;; Component 3: Symptom onset less than 12 hours before hospital admission (or less than 24 hours in case of ongoing myocardial ischemia)
(assert
  (! patient_has_finding_of_acute_myocardial_infarction_inthehistory@@diagnosed_by_symptom_onset_less_than_12_hours_before_hospital_admission_or_less_than_24_hours_in_case_of_ongoing_myocardial_ischemia
     :named REQ0_COMPONENT3_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have had symptom onset less than 12 hours before hospital admission (or less than 24 hours in case of ongoing myocardial ischemia)."

;; Component 4: Electrocardiogram showing ST-T segment elevation greater than 1 mV in 2 or more leads
(assert
  (! patient_has_finding_of_acute_myocardial_infarction_inthehistory@@diagnosed_by_electrocardiogram_showing_stt_segment_elevation_greater_than_1_mv_in_2_or_more_leads
     :named REQ0_COMPONENT4_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have had electrocardiogram showing ST-T segment elevation greater than 1 mV in 2 or more leads."

;; Component 5: TIMI grade 0 or 1 flow before PCI on diagnostic coronary angiography
(assert
  (! (or patient_has_finding_of_timi_grade_0_no_perfusion_inthepast1days@@present_before_primary_percutaneous_coronary_intervention_on_diagnostic_coronary_angiography
         patient_has_finding_of_timi_grade_1_penetration_without_perfusion_inthepast1days@@present_before_primary_percutaneous_coronary_intervention_on_diagnostic_coronary_angiography)
     :named REQ0_COMPONENT5_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have had Thrombolysis In Myocardial Infarction (TIMI) grade 0 flow or Thrombolysis In Myocardial Infarction (TIMI) grade 1 flow before primary percutaneous coronary intervention on diagnostic coronary angiography."
