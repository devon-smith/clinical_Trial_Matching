;; ===================== Declarations for the exclusion criterion (REQ 0) =====================
(declare-const patient_has_diagnosis_of_heart_failure_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever received a diagnosis of heart failure at any point in their medical history.","when_to_set_to_false":"Set to false if the patient has never received a diagnosis of heart failure.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever received a diagnosis of heart failure.","meaning":"Boolean indicating whether the patient has ever received a diagnosis of heart failure."} ;; "the patient has a diagnosis of heart failure"
(declare-const patient_has_diagnosis_of_cerebrovascular_accident_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever received a diagnosis of stroke (cerebrovascular accident) at any point in their medical history.","when_to_set_to_false":"Set to false if the patient has never received a diagnosis of stroke (cerebrovascular accident).","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever received a diagnosis of stroke (cerebrovascular accident).","meaning":"Boolean indicating whether the patient has ever received a diagnosis of stroke (cerebrovascular accident)."} ;; "the patient has a diagnosis of stroke"
(declare-const patient_has_diagnosis_of_atrial_fibrillation_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has ever received a diagnosis of atrial fibrillation at any point in their medical history.","when_to_set_to_false":"Set to false if the patient has never received a diagnosis of atrial fibrillation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever received a diagnosis of atrial fibrillation.","meaning":"Boolean indicating whether the patient has ever received a diagnosis of atrial fibrillation."} ;; "atrial fibrillation"
(declare-const patient_has_diagnosis_of_myocardial_infarction_before_diagnosis_of_atrial_fibrillation Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a diagnosis of myocardial infarction that occurred before the diagnosis of atrial fibrillation.","when_to_set_to_false":"Set to false if the patient has never had a diagnosis of myocardial infarction before the diagnosis of atrial fibrillation, or if all diagnoses of myocardial infarction occurred after or at the same time as the diagnosis of atrial fibrillation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient had a diagnosis of myocardial infarction before the diagnosis of atrial fibrillation.","meaning":"Boolean indicating whether the patient has a diagnosis of myocardial infarction that occurred before the diagnosis of atrial fibrillation."} ;; "the patient has a diagnosis of myocardial infarction occurring before diagnosis of atrial fibrillation"

;; ===================== Constraint Assertions (REQ 0) =====================
(assert
(! (not patient_has_diagnosis_of_heart_failure_inthehistory)
    :named REQ0_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient has a diagnosis of heart failure."

(assert
(! (not patient_has_diagnosis_of_cerebrovascular_accident_inthehistory)
    :named REQ0_COMPONENT1_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient has a diagnosis of stroke."

(assert
(! (not patient_has_diagnosis_of_myocardial_infarction_before_diagnosis_of_atrial_fibrillation)
    :named REQ0_COMPONENT2_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient has a diagnosis of myocardial infarction occurring before diagnosis of atrial fibrillation."
