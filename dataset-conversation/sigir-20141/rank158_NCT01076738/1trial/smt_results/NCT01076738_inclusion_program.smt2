;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_has_diagnosis_of_acute_coronary_syndrome_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a documented diagnosis of acute coronary syndrome at any time in their medical history.","when_to_set_to_false":"Set to false if the patient has no documented diagnosis of acute coronary syndrome at any time in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been diagnosed with acute coronary syndrome.","meaning":"Boolean indicating whether the patient has ever been diagnosed with acute coronary syndrome."} // "acute coronary syndrome"
(declare-const patient_has_diagnosis_of_unstable_angina_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a documented diagnosis of unstable angina at any time in their medical history.","when_to_set_to_false":"Set to false if the patient has no documented diagnosis of unstable angina at any time in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been diagnosed with unstable angina.","meaning":"Boolean indicating whether the patient has ever been diagnosed with unstable angina."} // "unstable angina"
(declare-const patient_has_diagnosis_of_non_q_wave_myocardial_infarction_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a documented diagnosis of non-Q-wave myocardial infarction at any time in their medical history.","when_to_set_to_false":"Set to false if the patient has no documented diagnosis of non-Q-wave myocardial infarction at any time in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been diagnosed with non-Q-wave myocardial infarction.","meaning":"Boolean indicating whether the patient has ever been diagnosed with non-Q-wave myocardial infarction."} // "non-Q-wave myocardial infarction"
(declare-const patient_has_diagnosis_of_q_wave_myocardial_infarction_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a documented diagnosis of Q-wave myocardial infarction at any time in their medical history.","when_to_set_to_false":"Set to false if the patient has no documented diagnosis of Q-wave myocardial infarction at any time in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been diagnosed with Q-wave myocardial infarction.","meaning":"Boolean indicating whether the patient has ever been diagnosed with Q-wave myocardial infarction."} // "Q-wave myocardial infarction"
(declare-const patient_has_diagnosis_of_ischemic_stroke_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a documented diagnosis of ischemic stroke at any time in their medical history.","when_to_set_to_false":"Set to false if the patient has no documented diagnosis of ischemic stroke at any time in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been diagnosed with ischemic stroke.","meaning":"Boolean indicating whether the patient has ever been diagnosed with ischemic stroke."} // "ischemic stroke"
(declare-const patient_has_diagnosis_of_transient_ischemic_attack_inthehistory Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a documented diagnosis of transient ischemic attack at any time in their medical history.","when_to_set_to_false":"Set to false if the patient has no documented diagnosis of transient ischemic attack at any time in their medical history.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has ever been diagnosed with transient ischemic attack.","meaning":"Boolean indicating whether the patient has ever been diagnosed with transient ischemic attack."} // "transient ischemic attack"

;; ===================== Auxiliary Assertions (REQ 0) =====================
;; Exhaustive subcategories for acute coronary syndrome: unstable angina OR non-Q-wave MI OR Q-wave MI
(assert
  (! (= patient_has_diagnosis_of_acute_coronary_syndrome_inthehistory
        (or patient_has_diagnosis_of_unstable_angina_inthehistory
            patient_has_diagnosis_of_non_q_wave_myocardial_infarction_inthehistory
            patient_has_diagnosis_of_q_wave_myocardial_infarction_inthehistory))
     :named REQ0_AUXILIARY0)) ;; "documented acute coronary syndrome (with exhaustive subcategories (documented unstable angina OR documented non-Q-wave myocardial infarction OR documented Q-wave myocardial infarction))"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Inclusion: patient must have (documented acute coronary syndrome OR documented ischemic stroke OR documented transient ischemic attack)
(assert
  (! (or patient_has_diagnosis_of_acute_coronary_syndrome_inthehistory
         patient_has_diagnosis_of_ischemic_stroke_inthehistory
         patient_has_diagnosis_of_transient_ischemic_attack_inthehistory)
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must have (documented acute coronary syndrome (with exhaustive subcategories (documented unstable angina OR documented non-Q-wave myocardial infarction OR documented Q-wave myocardial infarction)) OR documented ischemic stroke OR documented transient ischemic attack)."
