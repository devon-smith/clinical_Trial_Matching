;; ===================== Auxiliary Assertions (REQ 0) =====================
;; Qualifier variables imply corresponding stem variables
(assert
  (! (=> patient_has_finding_of_acute_pharyngitis_now@@evidence_based_on_erythematous_pharyngeal_mucosa_or_thick_exudate_covering_pharynx_and_tonsillar_area
         patient_has_finding_of_acute_pharyngitis_now)
     :named REQ0_AUXILIARY0)) ;; "acute pharyngitis evidence based on erythematous pharyngeal mucosa or thick exudate covering pharynx and tonsillar area"

(assert
  (! (=> patient_has_finding_of_acute_tonsillitis_now@@evidence_based_on_erythematous_pharyngeal_mucosa_or_thick_exudate_covering_pharynx_and_tonsillar_area
         patient_has_finding_of_acute_tonsillitis_now)
     :named REQ0_AUXILIARY1)) ;; "acute tonsillitis evidence based on erythematous pharyngeal mucosa or thick exudate covering pharynx and tonsillar area"

;; Exudate location qualifiers imply exudate
(assert
  (! (=> patient_is_exposed_to_exudate_now@@covering_pharynx
         patient_is_exposed_to_exudate_now)
     :named REQ0_AUXILIARY2)) ;; "exudate covering pharynx"

(assert
  (! (=> patient_is_exposed_to_exudate_now@@covering_tonsillar_area
         patient_is_exposed_to_exudate_now)
     :named REQ0_AUXILIARY3)) ;; "exudate covering tonsillar area"

;; Rash location qualifier implies rash
(assert
  (! (=> patient_has_finding_of_eruption_now@@located_on_skin_folds
         patient_has_finding_of_eruption_now)
     :named REQ0_AUXILIARY4)) ;; "rash located on skin folds"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: (evidence of acute pharyngitis OR evidence of acute tonsillitis) based on (erythematous pharyngeal mucosa OR (thick exudate covering pharynx AND thick exudate covering tonsillar area))
(assert
  (! (or
        patient_has_finding_of_acute_pharyngitis_now@@evidence_based_on_erythematous_pharyngeal_mucosa_or_thick_exudate_covering_pharynx_and_tonsillar_area
        patient_has_finding_of_acute_tonsillitis_now@@evidence_based_on_erythematous_pharyngeal_mucosa_or_thick_exudate_covering_pharynx_and_tonsillar_area)
     :named REQ0_COMPONENT0_OTHER_REQUIREMENTS)) ;; "To be included, the patient must have (evidence of acute pharyngitis OR evidence of acute tonsillitis) based on (erythematous pharyngeal mucosa OR thick exudate covering the pharynx AND thick exudate covering the tonsillar area)."

;; Component 1: At least one of the following signs or symptoms:
;; sore throat; scratchy throat; pain on swallowing; chills or fever; cervical adenopathy; scarlet fever rash on the face and scarlet fever rash on the skin folds; or red tongue with prominent papillae (strawberry tongue).
(assert
  (! (or
        patient_has_symptoms_of_pain_in_throat_now
        patient_has_symptoms_of_scratchy_throat_now
        patient_has_symptoms_of_swallowing_painful_now
        patient_has_symptoms_of_chill_now
        patient_has_symptoms_of_fever_now
        patient_has_finding_of_cervical_lymphadenopathy_now
        (and patient_has_finding_of_erythema_scarlatiniforme_now patient_has_finding_of_eruption_now@@located_on_skin_folds)
        (and patient_has_finding_of_red_tongue_now patient_has_finding_of_prominent_papillae_on_tongue_now)
        patient_has_finding_of_strawberry_tongue_now)
     :named REQ0_COMPONENT1_OTHER_REQUIREMENTS)) ;; "To be included, the patient must have at least one of the following signs or symptoms: sore throat; scratchy throat; pain on swallowing; chills or fever; cervical adenopathy; scarlet fever rash on the face and scarlet fever rash on the skin folds; or red tongue with prominent papillae (strawberry tongue)."

