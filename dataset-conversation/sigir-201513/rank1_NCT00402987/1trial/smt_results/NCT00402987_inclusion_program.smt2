(declare-const patient_is_exposed_to_drinks_now@@temporalcontext_between_hours_two_and_twenty_four Bool) ;; {"when_to_set_to_true":"Set to true if the patient is exposed to drink between hours two and twenty-four after trial drug administration.","when_to_set_to_false":"Set to false if the patient is not exposed to drink between hours two and twenty-four after trial drug administration.","when_to_set_to_null":"Set to null if it is unknown or cannot be determined whether the patient is exposed to drink between hours two and twenty-four after trial drug administration.","meaning":"Boolean indicating whether the patient is exposed to drink between hours two and twenty-four after trial drug administration."} ;; "allowed drink between hours two and twenty-four"
(declare-const patient_is_exposed_to_oral_treatments_now@@temporalcontext_between_hours_two_and_twenty_four Bool) ;; {"when_to_set_to_true":"Set to true if the patient is exposed to oral treatments between hours two and twenty-four after trial drug administration.","when_to_set_to_false":"Set to false if the patient is not exposed to oral treatments between hours two and twenty-four after trial drug administration.","when_to_set_to_null":"Set to null if it is unknown or cannot be determined whether the patient is exposed to oral treatments between hours two and twenty-four after trial drug administration.","meaning":"Boolean indicating whether the patient is exposed to oral treatments between hours two and twenty-four after trial drug administration."} ;; "NOT allowed other oral treatments between hours two and twenty-four"
(declare-const patient_is_undergoing_inhalation_therapy_procedure_now@@temporalcontext_between_hours_two_and_twenty_four Bool) ;; {"when_to_set_to_true":"Set to true if the patient is undergoing inhalation therapy procedure between hours two and twenty-four after trial drug administration.","when_to_set_to_false":"Set to false if the patient is not undergoing inhalation therapy procedure between hours two and twenty-four after trial drug administration.","when_to_set_to_null":"Set to null if it is unknown or cannot be determined whether the patient is undergoing inhalation therapy procedure between hours two and twenty-four after trial drug administration.","meaning":"Boolean indicating whether the patient is undergoing inhalation therapy procedure between hours two and twenty-four after trial drug administration."} ;; "NOT allowed inhaled treatments between hours two and twenty-four"
(declare-const patient_has_finding_of_tobacco_smoking_behavior_finding_now@@temporalcontext_between_hours_two_and_twenty_four Bool) ;; {"when_to_set_to_true":"Set to true if the patient is engaging in tobacco smoking behavior between hours two and twenty-four after trial drug administration.","when_to_set_to_false":"Set to false if the patient is not engaging in tobacco smoking behavior between hours two and twenty-four after trial drug administration.","when_to_set_to_null":"Set to null if it is unknown or cannot be determined whether the patient is engaging in tobacco smoking behavior between hours two and twenty-four after trial drug administration.","meaning":"Boolean indicating whether the patient is engaging in tobacco smoking behavior between hours two and twenty-four after trial drug administration."} ;; "NOT allowed smoking between hours two and twenty-four"
(declare-const patient_is_exposed_to_lozenges_now@@temporalcontext_between_hours_two_and_twenty_four Bool) ;; {"when_to_set_to_true":"Set to true if the patient is exposed to lozenges between hours two and twenty-four after trial drug administration.","when_to_set_to_false":"Set to false if the patient is not exposed to lozenges between hours two and twenty-four after trial drug administration.","when_to_set_to_null":"Set to null if it is unknown or cannot be determined whether the patient is exposed to lozenges between hours two and twenty-four after trial drug administration.","meaning":"Boolean indicating whether the patient is exposed to lozenges between hours two and twenty-four after trial drug administration."} ;; "NOT allowed lozenges between hours two and twenty-four"
(declare-const patient_is_exposed_to_chewing_gum_now@@temporalcontext_between_hours_two_and_twenty_four Bool) ;; {"when_to_set_to_true":"Set to true if the patient is exposed to chewing gum between hours two and twenty-four after trial drug administration.","when_to_set_to_false":"Set to false if the patient is not exposed to chewing gum between hours two and twenty-four after trial drug administration.","when_to_set_to_null":"Set to null if it is unknown or cannot be determined whether the patient is exposed to chewing gum between hours two and twenty-four after trial drug administration.","meaning":"Boolean indicating whether the patient is exposed to chewing gum between hours two and twenty-four after trial drug administration."} ;; "NOT allowed chewing gum between hours two and twenty-four"

;; ===================== Auxiliary Assertions (REQ 1) =====================
;; Non-exhaustive examples: smoking, lozenges, chewing gum are examples of oral/inhaled treatments
(assert
  (! (=> (or patient_has_finding_of_tobacco_smoking_behavior_finding_now@@temporalcontext_between_hours_two_and_twenty_four
            patient_is_exposed_to_lozenges_now@@temporalcontext_between_hours_two_and_twenty_four
            patient_is_exposed_to_chewing_gum_now@@temporalcontext_between_hours_two_and_twenty_four)
         (or patient_is_exposed_to_oral_treatments_now@@temporalcontext_between_hours_two_and_twenty_four
             patient_is_undergoing_inhalation_therapy_procedure_now@@temporalcontext_between_hours_two_and_twenty_four))
     :named REQ1_AUXILIARY0)) ;; "with non-exhaustive examples (smoking, lozenges, chewing gum)"

;; ===================== Constraint Assertions (REQ 1) =====================
;; Component 1: The patient must be allowed food AND allowed drink between hours two and twenty-four, but NOT allowed other oral treatments OR inhaled treatments (with non-exhaustive examples (smoking, lozenges, chewing gum)).
(assert
  (! (and patient_is_exposed_to_foods_now@@temporalcontext_between_hours_two_and_twenty_four
          patient_is_exposed_to_drinks_now@@temporalcontext_between_hours_two_and_twenty_four
          (not (or patient_is_exposed_to_oral_treatments_now@@temporalcontext_between_hours_two_and_twenty_four
                   patient_is_undergoing_inhalation_therapy_procedure_now@@temporalcontext_between_hours_two_and_twenty_four)))
     :named REQ1_COMPONENT1_NOT_REQUIREMNET_OR_ALWAYS_SATISFIABLE_WITH_ACTION)) ;; "allowed food AND allowed drink between hours two and twenty-four, but NOT allowed other oral treatments OR inhaled treatments"
