         patient_has_diagnosis_of_lymphadenitis_now@@diagnosis_based_on_clinical_data_or_laboratory_data)
    (and patient_has_diagnosis_of_pharyngitis_now@@confirmed_by_dr_bennett
         patient_has_diagnosis_of_pharyngitis_now@@diagnosis_based_on_clinical_data_or_laboratory_data)
    (and patient_has_diagnosis_of_recurrent_aphthous_ulcer_now@@confirmed_by_dr_bennett
         patient_has_diagnosis_of_recurrent_aphthous_ulcer_now@@diagnosis_based_on_clinical_data_or_laboratory_data)
  )
) ;; "confirmation of diagnosis ... from Dr. Bennett (based on clinical data OR laboratory data)"

