;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_sex_is_male_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient's sex is documented as male at the current time.","when_to_set_to_false":"Set to false if the patient's sex is documented as not male (e.g., female or other) at the current time.","when_to_set_to_null":"Set to null if the patient's sex is unknown, not documented, or cannot be determined at the current time.","meaning":"Boolean value indicating whether the patient's sex is male as currently recorded."} // "the patient must be a boy"
(declare-const patient_sex_is_female_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient's sex is documented as female at the current time.","when_to_set_to_false":"Set to false if the patient's sex is documented as not female (e.g., male or other) at the current time.","when_to_set_to_null":"Set to null if the patient's sex is unknown, not documented, or cannot be determined at the current time.","meaning":"Boolean value indicating whether the patient's sex is female as currently recorded."} // "the patient must be a girl"
(declare-const patient_age_value_recorded_on_day_of_first_vaccination_in_months Real) ;; {"when_to_set_to_value":"Set to the patient's age in months as recorded on the day of the first vaccination event if it is known and documented.","when_to_set_to_null":"Set to null if the patient's age in months on the day of first vaccination is unknown, not documented, or cannot be determined.","meaning":"Numeric value indicating the patient's age in months on the day of the first vaccination event."} // "aged greater than or equal to 6 months old and less than or equal to 12 months old on the day of first vaccination"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: To be included, the patient must be a boy OR (the patient must be a girl AND the patient must be aged >= 6 months and <= 12 months on the day of first vaccination)
(assert
  (! (or patient_sex_is_male_now
         (and patient_sex_is_female_now
              (>= patient_age_value_recorded_on_day_of_first_vaccination_in_months 6.0)
              (<= patient_age_value_recorded_on_day_of_first_vaccination_in_months 12.0)))
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "To be included, the patient must be a boy or the patient must be a girl and the patient must be aged greater than or equal to 6 months old and less than or equal to 12 months old on the day of first vaccination."

;; ===================== Declarations for the criterion (REQ 1) =====================
(declare-const patient_has_parent_willing_to_comply_with_study_procedures_and_available_for_all_study_visits Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a parent who is both willing to comply with planned study procedures and is available for all study visits.","when_to_set_to_false":"Set to false if the patient does not have a parent who meets both criteria.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has a parent who is willing to comply with planned study procedures and is available for all study visits.","meaning":"Boolean indicating whether the patient has a parent who is willing to comply with planned study procedures and is available for all study visits."} // "have a parent who is willing to comply with planned study procedures AND who is available for all study visits"
(declare-const patient_has_legal_guardian_willing_to_comply_with_study_procedures_and_available_for_all_study_visits Bool) ;; {"when_to_set_to_true":"Set to true if the patient has a legal guardian who is both willing to comply with planned study procedures and is available for all study visits.","when_to_set_to_false":"Set to false if the patient does not have a legal guardian who meets both criteria.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient has a legal guardian who is willing to comply with planned study procedures and is available for all study visits.","meaning":"Boolean indicating whether the patient has a legal guardian who is willing to comply with planned study procedures and is available for all study visits."} // "have a legal guardian who is willing to comply with planned study procedures AND who is available for all study visits"

;; ===================== Constraint Assertions (REQ 1) =====================
(assert
  (! (or patient_has_parent_willing_to_comply_with_study_procedures_and_available_for_all_study_visits
         patient_has_legal_guardian_willing_to_comply_with_study_procedures_and_available_for_all_study_visits)
     :named REQ1_COMPONENT0_NOT_REQUIREMNET_OR_ALWAYS_SATISFIABLE_WITH_ACTION)) ;; "must ((have a parent who is willing to comply with planned study procedures AND who is available for all study visits) OR (have a legal guardian who is willing to comply with planned study procedures AND who is available for all study visits))"

;; ===================== Declarations for the criterion (REQ 2) =====================
(declare-const patient_is_in_good_physical_health_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently in good physical health.","when_to_set_to_false":"Set to false if the patient is currently not in good physical health.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently in good physical health.","meaning":"Boolean indicating whether the patient is currently in good physical health."} // "the patient must be in good physical health"
(declare-const patient_is_in_good_physical_health_now@@based_on_medical_history_and_physical_examination Bool) ;; {"when_to_set_to_true":"Set to true if the determination that the patient is in good physical health is based on both medical history and physical examination.","when_to_set_to_false":"Set to false if the determination that the patient is in good physical health is not based on both medical history and physical examination.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the determination of good physical health is based on both medical history and physical examination.","meaning":"Boolean indicating whether the determination of good physical health is based on both medical history and physical examination."} // "on the basis of medical history AND physical examination"

;; ===================== Auxiliary Assertions (REQ 2) =====================
;; Qualifier variable implies corresponding stem variable
(assert
  (! (=> patient_is_in_good_physical_health_now@@based_on_medical_history_and_physical_examination
         patient_is_in_good_physical_health_now)
     :named REQ2_AUXILIARY0)) ;; "on the basis of medical history AND physical examination" implies "in good physical health"

;; ===================== Constraint Assertions (REQ 2) =====================
(assert
  (! patient_is_in_good_physical_health_now@@based_on_medical_history_and_physical_examination
     :named REQ2_COMPONENT0_OTHER_REQUIREMENTS)) ;; "the patient must be in good physical health (on the basis of medical history AND physical examination)"

;; ===================== Declarations for the criterion (REQ 3) =====================
(declare-const parent_has_read_and_signed_study_specific_informed_consent_prior_to_study_procedure_initiation Bool) ;; {"when_to_set_to_true":"Set to true if the patient's parent has read and signed the study-specific informed consent before any study procedure is initiated.","when_to_set_to_false":"Set to false if the patient's parent has not read and signed the study-specific informed consent before any study procedure is initiated.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's parent has read and signed the study-specific informed consent prior to initiation of any study procedure.","meaning":"Boolean indicating whether the patient's parent has read and signed the study-specific informed consent prior to initiation of any study procedure."} // "have a parent who has read and signed the study-specific informed consent prior to initiation of any study procedure"
(declare-const legal_guardian_has_read_and_signed_study_specific_informed_consent_prior_to_study_procedure_initiation Bool) ;; {"when_to_set_to_true":"Set to true if the patient's legal guardian has read and signed the study-specific informed consent before any study procedure is initiated.","when_to_set_to_false":"Set to false if the patient's legal guardian has not read and signed the study-specific informed consent before any study procedure is initiated.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient's legal guardian has read and signed the study-specific informed consent prior to initiation of any study procedure.","meaning":"Boolean indicating whether the patient's legal guardian has read and signed the study-specific informed consent prior to initiation of any study procedure."} // "have a legal guardian who has read and signed the study-specific informed consent prior to initiation of any study procedure"

;; ===================== Constraint Assertions (REQ 3) =====================
(assert
  (! (or parent_has_read_and_signed_study_specific_informed_consent_prior_to_study_procedure_initiation
         legal_guardian_has_read_and_signed_study_specific_informed_consent_prior_to_study_procedure_initiation)
     :named REQ3_COMPONENT0_NOT_REQUIREMNET_OR_ALWAYS_SATISFIABLE_WITH_ACTION)) ;; "To be included, the patient must ((have a parent who has read and signed the study-specific informed consent prior to initiation of any study procedure) OR (have a legal guardian who has read and signed the study-specific informed consent prior to initiation of any study procedure))."
