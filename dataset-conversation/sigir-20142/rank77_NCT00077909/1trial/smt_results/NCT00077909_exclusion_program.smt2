;; ===================== Declarations for the exclusion criterion (REQ 0) =====================
(declare-const patient_is_undergoing_bronchoscopy_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently undergoing bronchoscopy at the time of assessment.","when_to_set_to_false":"Set to false if the patient is not currently undergoing bronchoscopy at the time of assessment.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently undergoing bronchoscopy.","meaning":"Boolean indicating whether the patient is currently undergoing bronchoscopy."} ;; "the patient is undergoing bronchoscopy"
(declare-const patient_wants_to_participate_in_chart_review_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently wants to participate in chart review.","when_to_set_to_false":"Set to false if the patient currently does not want to participate in chart review.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently wants to participate in chart review.","meaning":"Boolean indicating whether the patient currently wants to participate in chart review."} ;; "the patient does NOT want to participate in chart review"
(declare-const patient_wants_to_participate_in_proteomic_analysis_of_bronchoalveolar_lavage_fluid_supernatant_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently wants to participate in proteomic analysis of bronchoalveolar lavage fluid supernatant.","when_to_set_to_false":"Set to false if the patient currently does not want to participate in proteomic analysis of bronchoalveolar lavage fluid supernatant.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently wants to participate in proteomic analysis of bronchoalveolar lavage fluid supernatant.","meaning":"Boolean indicating whether the patient currently wants to participate in proteomic analysis of bronchoalveolar lavage fluid supernatant."} ;; "the patient does NOT want to participate in proteomic analysis of bronchoalveolar lavage fluid supernatant"

;; ===================== Constraint Assertions (REQ 0) =====================
(assert
(! (not (and patient_is_undergoing_bronchoscopy_now
             (or (not patient_wants_to_participate_in_chart_review_now)
                 (not patient_wants_to_participate_in_proteomic_analysis_of_bronchoalveolar_lavage_fluid_supernatant_now))))
:named REQ0_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if (the patient is undergoing bronchoscopy) AND ((the patient does NOT want to participate in chart review) OR (the patient does NOT want to participate in proteomic analysis of bronchoalveolar lavage fluid supernatant))."
