;; ===================== Declarations for the exclusion criterion (REQ 1) =====================
(declare-const clinical_site_requires_informed_consent_now Bool) ;; {"when_to_set_to_true":"Set to true if the clinical site currently requires informed consent for participation.","when_to_set_to_false":"Set to false if the clinical site does not currently require informed consent for participation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the clinical site currently requires informed consent for participation.","meaning":"Boolean indicating whether the clinical site currently requires informed consent for participation."} ;; "clinical site requiring informed consent"
(declare-const patient_is_unable_to_understand_informed_consent_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently unable to understand informed consent.","when_to_set_to_false":"Set to false if the patient is currently able to understand informed consent.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently unable to understand informed consent.","meaning":"Boolean indicating whether the patient is currently unable to understand informed consent."} ;; "patient is unable to understand informed consent"
