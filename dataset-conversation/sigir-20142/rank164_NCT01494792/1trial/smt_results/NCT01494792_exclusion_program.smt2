(declare-const patient_is_minor_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently a minor according to the legal age of consent at the clinical site.","when_to_set_to_false":"Set to false if the patient is not currently a minor according to the legal age of consent at the clinical site.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently a minor according to the legal age of consent at the clinical site.","meaning":"Boolean indicating whether the patient is currently a minor according to the legal age of consent at the clinical site."} ;; "the patient is a minor"
(declare-const parent_of_patient_is_unable_to_understand_informed_consent_now Bool) ;; {"when_to_set_to_true":"Set to true if the parent of the patient is currently unable to understand informed consent.","when_to_set_to_false":"Set to false if the parent of the patient is currently able to understand informed consent.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the parent of the patient is currently unable to understand informed consent.","meaning":"Boolean indicating whether the parent of the patient is currently unable to understand informed consent."} ;; "parent of the patient is unable to understand informed consent"
(declare-const parent_of_patient_is_unable_to_consent_to_participation_now Bool) ;; {"when_to_set_to_true":"Set to true if the parent of the patient is currently unable to consent to participation.","when_to_set_to_false":"Set to false if the parent of the patient is currently able to consent to participation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the parent of the patient is currently unable to consent to participation.","meaning":"Boolean indicating whether the parent of the patient is currently unable to consent to participation."} ;; "parent of the patient is unable to consent to participation"
(declare-const legal_guardian_of_patient_is_unable_to_understand_informed_consent_now Bool) ;; {"when_to_set_to_true":"Set to true if the legal guardian of the patient is currently unable to understand informed consent.","when_to_set_to_false":"Set to false if the legal guardian of the patient is currently able to understand informed consent.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the legal guardian of the patient is currently unable to understand informed consent.","meaning":"Boolean indicating whether the legal guardian of the patient is currently unable to understand informed consent."} ;; "legal guardian of the patient is unable to understand informed consent"
(declare-const legal_guardian_of_patient_is_unable_to_consent_to_participation_now Bool) ;; {"when_to_set_to_true":"Set to true if the legal guardian of the patient is currently unable to consent to participation.","when_to_set_to_false":"Set to false if the legal guardian of the patient is currently able to consent to participation.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the legal guardian of the patient is currently unable to consent to participation.","meaning":"Boolean indicating whether the legal guardian of the patient is currently unable to consent to participation."} ;; "legal guardian of the patient is unable to consent to participation"
(declare-const patient_age_value_recorded_now_in_years Real) ;; {"when_to_set_to_value":"Set to the patient's current age in years if it is known and documented.","when_to_set_to_null":"Set to null if the patient's current age in years is unknown, not documented, or cannot be determined.","meaning":"Numeric value indicating the patient's current age in years."} ;; "the patient is a minor"

;; ===================== Constraint Assertions (REQ 1) =====================
;; Exclusion if at a clinical site requiring informed consent and patient is unable to understand and unable to consent
(assert
(! (not (and clinical_site_requires_informed_consent_now
             patient_is_unable_to_understand_informed_consent_now
             patient_is_unable_to_consent_to_participation_now))
:named REQ1_COMPONENT0_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient is at a clinical site requiring informed consent AND the patient is unable to understand informed consent AND the patient is unable to consent to participation."

