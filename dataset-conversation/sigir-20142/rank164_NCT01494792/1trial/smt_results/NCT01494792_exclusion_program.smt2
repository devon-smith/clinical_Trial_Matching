(! (not (and clinical_site_requires_informed_consent_now
             patient_is_minor_now
             parent_of_patient_is_unable_to_understand_informed_consent_now
             parent_of_patient_is_unable_to_consent_to_participation_now))
:named REQ1_COMPONENT1_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient is at a clinical site requiring informed consent AND the patient is a minor AND the parent of the patient is unable to understand informed consent AND the parent of the patient is unable to consent to participation."

;; Exclusion if at a clinical site requiring informed consent, patient is a minor, and legal guardian is unable to understand and unable to consent
(assert
(! (not (and clinical_site_requires_informed_consent_now
             patient_is_minor_now
             legal_guardian_of_patient_is_unable_to_understand_informed_consent_now
             legal_guardian_of_patient_is_unable_to_consent_to_participation_now))
:named REQ1_COMPONENT2_OTHER_REQUIREMENTS)) ;; "The patient is excluded if the patient is at a clinical site requiring informed consent AND the patient is a minor AND the legal guardian of the patient is unable to understand informed consent AND the legal guardian of the patient is unable to consent to participation."
