(declare-const patient_has_diagnosis_of_allergic_rhinitis_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently meets criteria for classification as having allergic rhinitis.","when_to_set_to_false":"Set to false if the patient currently does not meet criteria for classification as having allergic rhinitis.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently meets criteria for classification as having allergic rhinitis.","meaning":"Boolean indicating whether the patient currently has a diagnosis of allergic rhinitis."} ;; "allergic rhinitis"
(declare-const patient_has_diagnosis_of_asthma_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently meets criteria for classification as having asthma.","when_to_set_to_false":"Set to false if the patient currently does not meet criteria for classification as having asthma.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently meets criteria for classification as having asthma.","meaning":"Boolean indicating whether the patient currently has a diagnosis of asthma."} ;; "asthma"
(declare-const patient_methacholine_value_recorded_now_withunit_milligrams_per_milliliter Real) ;; {"when_to_set_to_value":"Set to the measured value (in mg/mL) of the provocative concentration of methacholine producing a 20 percent fall in FEV1, measured now by the method used.","when_to_set_to_null":"Set to null if no such measurement is available now or the value is indeterminate.","meaning":"Numeric value representing the provocative concentration of methacholine (mg/mL) producing a 20 percent fall in FEV1, measured now."} ;; "provocative concentration of methacholine producing a 20 percent fall in FEV1 < 10 mg/mL by the method used"
(declare-const patient_methacholine_value_recorded_now_withunit_milligrams_per_milliliter@@measured_by_the_method_used Bool) ;; {"when_to_set_to_true":"Set to true if the provocative concentration of methacholine value was measured by the method used.","when_to_set_to_false":"Set to false if the provocative concentration of methacholine value was not measured by the method used.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the measurement was performed by the method used.","meaning":"Boolean indicating whether the provocative concentration of methacholine value was measured by the method used."} ;; "measured by the method used"

;; ===================== Auxiliary Assertions (REQ 4) =====================
;; If the qualifier is true, the measurement is by the method used
(assert
  (! (=> patient_methacholine_value_recorded_now_withunit_milligrams_per_milliliter@@measured_by_the_method_used
         (<= patient_methacholine_value_recorded_now_withunit_milligrams_per_milliliter 10.0))
     :named REQ4_AUXILIARY0)) ;; "provocative concentration of methacholine producing a 20 percent fall in FEV1 < 10 mg/mL by the method used"

;; ===================== Constraint Assertions (REQ 4) =====================
;; Inclusion: patient must have (asthma with allergic rhinitis) OR (allergic rhinitis alone), and must meet the methacholine criterion
(assert
  (! (and
        (or
          (and patient_has_diagnosis_of_asthma_now patient_has_diagnosis_of_allergic_rhinitis_now)
          (and (not patient_has_diagnosis_of_asthma_now) patient_has_diagnosis_of_allergic_rhinitis_now)
        )
        patient_methacholine_value_recorded_now_withunit_milligrams_per_milliliter@@measured_by_the_method_used
        (< patient_methacholine_value_recorded_now_withunit_milligrams_per_milliliter 10.0)
     )
     :named REQ4_COMPONENT0_OTHER_REQUIREMENTS))
