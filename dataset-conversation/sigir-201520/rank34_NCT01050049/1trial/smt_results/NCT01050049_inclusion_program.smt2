;; ===================== Declarations for the criterion (REQ 0) =====================
(declare-const patient_has_presented_to_emergency_department_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient is currently presenting to the emergency department.","when_to_set_to_false":"Set to false if the patient is not currently presenting to the emergency department.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient is currently presenting to the emergency department.","meaning":"Boolean indicating whether the patient is currently presenting to the emergency department."} // "present to the emergency department"
(declare-const patient_has_signs_and_symptoms_of_acute_ischemic_stroke_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has signs and symptoms that are acute and caused by ischemic stroke.","when_to_set_to_false":"Set to false if the patient currently does not have signs and symptoms that are acute and caused by ischemic stroke.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has signs and symptoms that are acute and caused by ischemic stroke.","meaning":"Boolean indicating whether the patient currently has signs and symptoms that are acute and caused by ischemic stroke."} // "signs and symptoms of acute ischemic stroke"
(declare-const patient_has_finding_of_disorder_of_language_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has the clinical finding of disorder of language (impairment of language function).","when_to_set_to_false":"Set to false if the patient currently does not have the clinical finding of disorder of language.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has the clinical finding of disorder of language.","meaning":"Boolean indicating whether the patient currently has the clinical finding of disorder of language."} // "impairment of language function"
(declare-const patient_has_finding_of_motor_dysfunction_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has the clinical finding of motor dysfunction (impairment of motor function).","when_to_set_to_false":"Set to false if the patient currently does not have the clinical finding of motor dysfunction.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has the clinical finding of motor dysfunction.","meaning":"Boolean indicating whether the patient currently has the clinical finding of motor dysfunction."} // "impairment of motor function"
(declare-const patient_has_finding_of_impaired_cognition_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has the clinical finding of impaired cognition (impairment of cognitive function).","when_to_set_to_false":"Set to false if the patient currently does not have the clinical finding of impaired cognition.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has the clinical finding of impaired cognition.","meaning":"Boolean indicating whether the patient currently has the clinical finding of impaired cognition."} // "impairment of cognitive function"
(declare-const patient_has_finding_of_disorder_of_gaze_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has the clinical finding of disorder of gaze (impairment of gaze function).","when_to_set_to_false":"Set to false if the patient currently does not have the clinical finding of disorder of gaze.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has the clinical finding of disorder of gaze.","meaning":"Boolean indicating whether the patient currently has the clinical finding of disorder of gaze (impairment of gaze function)."} // "impairment of gaze function"
(declare-const patient_has_finding_of_abnormal_vision_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has the clinical finding of abnormal vision (impairment of vision function).","when_to_set_to_false":"Set to false if the patient currently does not have the clinical finding of abnormal vision.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has the clinical finding of abnormal vision.","meaning":"Boolean indicating whether the patient currently has the clinical finding of abnormal vision."} // "impairment of vision function"
(declare-const patient_has_finding_of_disorder_of_neglect_now Bool) ;; {"when_to_set_to_true":"Set to true if the patient currently has the clinical finding of disorder of neglect (impairment of neglect function).","when_to_set_to_false":"Set to false if the patient currently does not have the clinical finding of disorder of neglect.","when_to_set_to_null":"Set to null if it is unknown, not documented, or cannot be determined whether the patient currently has the clinical finding of disorder of neglect.","meaning":"Boolean indicating whether the patient currently has the clinical finding of disorder of neglect (impairment of neglect function)."} // "impairment of neglect function"

;; ===================== Constraint Assertions (REQ 0) =====================
;; Component 0: "present to the emergency department with signs and symptoms of acute ischemic stroke"
(assert
  (! (and patient_has_presented_to_emergency_department_now
          patient_has_signs_and_symptoms_of_acute_ischemic_stroke_now)
     :named REQ0_COMPONENT0_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "present to the emergency department with signs and symptoms of acute ischemic stroke"

;; Component 1: "at least one impairment of language function OR at least one impairment of motor function OR at least one impairment of cognitive function OR at least one impairment of gaze function OR at least one impairment of vision function OR at least one impairment of neglect function"
(assert
  (! (or patient_has_finding_of_disorder_of_language_now
         patient_has_finding_of_motor_dysfunction_now
         patient_has_finding_of_impaired_cognition_now
         patient_has_finding_of_disorder_of_gaze_now
         patient_has_finding_of_abnormal_vision_now
         patient_has_finding_of_disorder_of_neglect_now)
     :named REQ0_COMPONENT1_PRESCREEN_NOTES_MUST_COMPLETELY_SUFFICE)) ;; "at least one impairment of language function OR at least one impairment of motor function OR at least one impairment of cognitive function OR at least one impairment of gaze function OR at least one impairment of vision function OR at least one impairment of neglect function"

;; ===================== Declarations for the criterion (REQ 1) =====================
(declare-const patient_national_institutes_of_health_stroke_scale_score_value_recorded_now_withunit_score Real) ;; {"when_to_set_to_value":"Set to the measured value if the patient's National Institutes of Health Stroke Scale score is recorded now.","when_to_set_to_null":"Set to null if no such score is recorded now or the value is indeterminate.","meaning":"Numeric value representing the patient's current National Institutes of Health Stroke Scale score."} // "National Institutes of Health Stroke Scale score"

;; ===================== Constraint Assertions (REQ 1) =====================
(assert
  (! (> patient_national_institutes_of_health_stroke_scale_score_value_recorded_now_withunit_score 4.0)
     :named REQ1_COMPONENT0_OTHER_REQUIREMENTS)) ;; "To be included, the patient must have a National Institutes of Health Stroke Scale score greater than 4."
